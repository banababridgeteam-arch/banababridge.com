---
import { SITE } from '../config';
import {
  type Lang,
  defaultLang,
  langOrder,
  langLocale,
  langHreflang,
  localizePath,
  useTranslations,
} from '../i18n/ui';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CallBar from '../components/CallBar.astro';
import '../styles/global.css';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  jsonLd?: object[];
  ogType?: string;
  noindex?: boolean;
  /** 홈처럼 3개 언어가 모두 존재하는 페이지면 true → hreflang 출력 */
  i18nAlternates?: boolean;
  /** hreflang 계산용 로케일 무접두어 경로 (기본 '/') */
  basePath?: string;
}

const {
  lang = defaultLang,
  title,
  description,
  jsonLd = [],
  ogType = 'website',
  noindex = false,
  i18nAlternates = false,
  basePath = '/',
} = Astro.props;

const t = useTranslations(lang);
const pageTitle = title ? `${title} | ${SITE.name}` : t.meta.title;
const desc = description ?? t.meta.desc;
const canonical = new URL(Astro.url.pathname, SITE.url).href;

const baseJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${SITE.url}/#organization`,
    name: SITE.legalName,
    alternateName: [SITE.name, SITE.legalNameEn],
    url: SITE.url,
    logo: `${SITE.url}/favicon.svg`,
    description: t.meta.desc,
    foundingDate: SITE.foundingDate,
    email: SITE.email,
    ...(SITE.phone ? { telephone: SITE.phone } : {}),
    address: {
      '@type': 'PostalAddress',
      streetAddress: '대지로 43, 6층 606-746호',
      addressLocality: '용인시 수지구',
      addressRegion: '경기도',
      addressCountry: 'KR',
    },
    ...(SITE.sameAs.length ? { sameAs: SITE.sameAs } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${SITE.url}/#website`,
    url: SITE.url,
    name: SITE.name,
    inLanguage: langHreflang[lang],
    publisher: { '@id': `${SITE.url}/#organization` },
  },
];
const allJsonLd = [...baseJsonLd, ...jsonLd];
---

<!doctype html>
<html lang={langHreflang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#070b1c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="BANABA BRIDGE Insights"
      href="/rss.xml"
    />

    {i18nAlternates && langOrder.map((l) => (
      <link
        rel="alternate"
        hreflang={langHreflang[l]}
        href={new URL(localizePath(basePath, l), SITE.url).href}
      />
    ))}
    {i18nAlternates && (
      <link rel="alternate" hreflang="x-default" href={new URL(basePath, SITE.url).href} />
    )}

    {SITE.googleVerification && (
      <meta name="google-site-verification" content={SITE.googleVerification} />
    )}
    {SITE.naverVerification && (
      <meta name="naver-site-verification" content={SITE.naverVerification} />
    )}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${SITE.url}/og-default.jpg`} />
    <meta property="og:locale" content={langLocale[lang]} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={`${SITE.url}/og-default.jpg`} />

    {/* Inter (라틴 대형 타이포) + Pretendard (한글). 중문은 시스템 CJK 폰트 */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/gh/orioncactus/pretendard@v1.3.9/dist/web/variable/pretendardvariable-dynamic-subset.min.css"
      crossorigin="anonymous"
    />

    <noscript>
      <style is:inline>.reveal{opacity:1 !important;transform:none !important}.mask-head .ml>span{transform:none !important}</style>
    </noscript>

    {allJsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    {SITE.ga4 && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.ga4}`}></script>
        <script
          is:inline
          set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${SITE.ga4}');`}
        />
      </>
    )}
  </head>
  <body>
    <div class="cursor" id="cursor" aria-hidden="true"></div>

    <Header lang={lang} basePath={basePath} i18nAlternates={i18nAlternates} />
    <slot />
    <Footer lang={lang} />
    <CallBar lang={lang} />

    {SITE.cfBeaconToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${SITE.cfBeaconToken}"}`}></script>
    )}

    <script>
      // 스크롤 리빌 (fade/up + 마스크 라인)
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));

      // 커스텀 커서 (데스크톱 포인터 · reduced-motion 아님)
      const fine = matchMedia('(hover: hover) and (pointer: fine)').matches;
      const noMotion = matchMedia('(prefers-reduced-motion: reduce)').matches;
      const cursor = document.getElementById('cursor');
      if (cursor && fine && !noMotion) {
        document.body.classList.add('has-cursor');
        let cx = innerWidth / 2, cy = innerHeight / 2, x = cx, y = cy, raf = 0;
        const loop = () => {
          x += (cx - x) * 0.18;
          y += (cy - y) * 0.18;
          cursor.style.transform = `translate(${x}px, ${y}px) translate(-50%, -50%)`;
          raf = requestAnimationFrame(loop);
        };
        addEventListener('mousemove', (e) => {
          cx = e.clientX; cy = e.clientY;
          cursor.classList.add('on');
          if (!raf) raf = requestAnimationFrame(loop);
        }, { passive: true });
        addEventListener('mouseout', (e) => { if (!e.relatedTarget) cursor.classList.remove('on'); });
        const hoverSel = 'a, button, [data-cursor], video, summary, input, .work-card';
        addEventListener('mouseover', (e) => {
          if ((e.target as Element).closest?.(hoverSel)) cursor.classList.add('hover');
        }, { passive: true });
        addEventListener('mouseout', (e) => {
          if ((e.target as Element).closest?.(hoverSel)) cursor.classList.remove('hover');
        }, { passive: true });
      }
    </script>
  </body>
</html>
