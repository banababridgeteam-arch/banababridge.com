---
// 셀프호스트 폰트 (외부 CDN 제거 → 렌더블로킹·프라이버시 개선). Inter=opsz+wght 가변, Pretendard=동적 서브셋
import '@fontsource-variable/inter/standard.css';
import 'pretendard/dist/web/variable/pretendardvariable-dynamic-subset.css';
import { SITE } from '../config';
import {
  type Lang,
  defaultLang,
  langOrder,
  langLocale,
  langHreflang,
  localizePath,
  useTranslations,
  ui,
} from '../i18n/ui';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CallBar from '../components/CallBar.astro';
import '../styles/global.css';

interface Props {
  lang?: Lang;
  title?: string;
  description?: string;
  jsonLd?: object[];
  ogType?: string;
  noindex?: boolean;
  /** 홈처럼 3개 언어가 모두 존재하는 페이지면 true → hreflang 출력 */
  i18nAlternates?: boolean;
  /** hreflang 계산용 로케일 무접두어 경로 (기본 '/') */
  basePath?: string;
}

const {
  lang = defaultLang,
  title,
  description,
  jsonLd = [],
  ogType = 'website',
  noindex = false,
  i18nAlternates = false,
  basePath = '/',
} = Astro.props;

const t = useTranslations(lang);
const pageTitle = title ? `${title} | ${SITE.name}` : t.meta.title;
const desc = description ?? t.meta.desc;
const canonical = new URL(Astro.url.pathname, SITE.url).href;

const baseJsonLd = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    '@id': `${SITE.url}/#organization`,
    name: SITE.legalName,
    alternateName: [SITE.name, SITE.legalNameEn],
    url: SITE.url,
    logo: {
      '@type': 'ImageObject',
      url: `${SITE.url}/favicon.svg`,
      contentUrl: `${SITE.url}/logo.png`,
    },
    image: `${SITE.url}/og-default.jpg`,
    description: t.meta.desc,
    slogan: '아티스트에겐 무대를, 브랜드에겐 시장을',
    foundingDate: SITE.foundingDate,
    email: SITE.email,
    ...(SITE.phone ? { telephone: SITE.phone } : {}),
    knowsLanguage: ['ko', 'en', 'zh', 'vi'],
    areaServed: ['KR', 'CN', 'JP', 'VN'],
    address: {
      '@type': 'PostalAddress',
      streetAddress: '대지로 43, 6층 606-746호',
      addressLocality: '용인시 수지구',
      addressRegion: '경기도',
      addressCountry: 'KR',
    },
    contactPoint: {
      '@type': 'ContactPoint',
      contactType: 'customer service',
      email: SITE.email,
      ...(SITE.phone ? { telephone: SITE.phone } : {}),
      availableLanguage: ['Korean', 'English', 'Chinese', 'Vietnamese'],
    },
    hasOfferCatalog: {
      '@type': 'OfferCatalog',
      name: 'BANABA BRIDGE 서비스',
      itemListElement: ui.ko.services.items.map((s) => ({
        '@type': 'Offer',
        itemOffered: { '@type': 'Service', name: s.title, description: s.desc },
      })),
    },
    ...(SITE.sameAs.length ? { sameAs: SITE.sameAs } : {}),
  },
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    '@id': `${SITE.url}/#website`,
    url: SITE.url,
    name: SITE.name,
    inLanguage: langHreflang[lang],
    publisher: { '@id': `${SITE.url}/#organization` },
  },
];
const allJsonLd = [...baseJsonLd, ...jsonLd];
---

<!doctype html>
<html lang={langHreflang[lang]}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <link rel="canonical" href={canonical} />
    {noindex && <meta name="robots" content="noindex, nofollow" />}
    <meta name="theme-color" content="#070b1c" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link
      rel="alternate"
      type="application/rss+xml"
      title="BANABA BRIDGE Insights"
      href="/rss.xml"
    />

    {i18nAlternates && langOrder.map((l) => (
      <link
        rel="alternate"
        hreflang={langHreflang[l]}
        href={new URL(localizePath(basePath, l), SITE.url).href}
      />
    ))}
    {i18nAlternates && (
      <link rel="alternate" hreflang="x-default" href={new URL(basePath, SITE.url).href} />
    )}

    {SITE.googleVerification && (
      <meta name="google-site-verification" content={SITE.googleVerification} />
    )}
    {SITE.naverVerification && (
      <meta name="naver-site-verification" content={SITE.naverVerification} />
    )}

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={`${SITE.url}/og-default.jpg`} />
    <meta property="og:locale" content={langLocale[lang]} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={desc} />
    <meta name="twitter:image" content={`${SITE.url}/og-default.jpg`} />

    {/* 폰트는 셀프호스트(@fontsource Inter + pretendard) — Base 프론트매터에서 import. 외부 CDN 미사용 */}

    <noscript>
      <style is:inline>.reveal{opacity:1 !important;transform:none !important}.mask-head .ml>span{transform:none !important}</style>
    </noscript>

    {allJsonLd.map((block) => (
      <script type="application/ld+json" set:html={JSON.stringify(block)} />
    ))}

    {SITE.ga4 && (
      <>
        <script async src={`https://www.googletagmanager.com/gtag/js?id=${SITE.ga4}`}></script>
        <script
          is:inline
          set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${SITE.ga4}');`}
        />
      </>
    )}
  </head>
  <body>
    <Header lang={lang} basePath={basePath} i18nAlternates={i18nAlternates} />
    <slot />
    <Footer lang={lang} />
    <CallBar lang={lang} />

    {SITE.cfBeaconToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${SITE.cfBeaconToken}"}`}></script>
    )}

    <script>
      // 스크롤 리빌 (fade/up + 마스크 라인)
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('in');
              io.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12 }
      );
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el));
    </script>
  </body>
</html>
