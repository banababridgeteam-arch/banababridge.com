---
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

// 각 서비스의 대형 이니셜 글리프 (언어 무관)
const abbr = ['E', 'F', 'A', 'D', 'AX'];
const N = t.services.items.length;
---

<section class="svc-3d" id="services" style={`--n:${N}`}>
  <div class="svc-pin">
    <div class="svc-pin-head">
      <span class="svc-eyebrow">(03)&nbsp;&nbsp;SERVICES</span>
      <h2 class="svc-heading display">{t.services.head}</h2>
    </div>

    <div class="svc-stage">
      <ul class="svc-deck" id="svc-fan">
        {t.services.items.map((s, i) => (
          <li class={`svc-card${abbr[i].length > 1 ? ' is-wide' : ''}`} data-i={i}>
            <span class="card-glyph" aria-hidden="true">{abbr[i]}</span>
            <span class="card-no">{s.no}</span>
            <div class="card-body">
              <span class="card-cat">{t.services.label}</span>
              <h3 class="card-title display">{s.title}</h3>
              <p class="card-desc">{s.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <div class="svc-dots" aria-hidden="true">
      {t.services.items.map((_, i) => <span data-i={i}></span>)}
    </div>
  </div>
</section>

<style>
  /* ── 모바일 우선(정적 스택) ── */
  .svc-3d { position: relative; padding: clamp(60px, 7vw, 100px) 0; }
  .svc-pin { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }
  .svc-pin-head { text-align: center; margin-bottom: clamp(28px, 4vw, 44px); }
  .svc-eyebrow {
    font-family: var(--font-display);
    font-size: 12.5px; font-weight: 500; letter-spacing: 0.22em;
    color: var(--violet); text-transform: uppercase;
  }
  .svc-heading {
    margin-top: 12px;
    font-size: clamp(32px, 5.4vw, 76px);
    font-weight: 600; letter-spacing: -0.05em; line-height: 1.05;
  }
  .svc-deck { list-style: none; display: flex; flex-direction: column; gap: 18px; }

  .svc-card {
    position: relative;
    overflow: hidden;
    background: linear-gradient(158deg, #161d40 0%, #0a0e26 62%);
    border: 1px solid rgba(185, 169, 224, 0.22);
    border-radius: 26px;
    padding: clamp(26px, 3.4vw, 42px);
    min-height: clamp(300px, 64vw, 420px);
    display: flex; flex-direction: column; justify-content: flex-end;
    box-shadow: 0 44px 100px -50px rgba(8, 6, 24, 0.95);
  }
  /* 하단 스크림 — 거대 글리프 위 제목 가독 */
  .svc-card::after {
    content: '';
    position: absolute; inset: auto 0 0 0; height: 58%;
    background: linear-gradient(transparent, #0a0e26 82%);
    pointer-events: none;
  }
  .card-no {
    position: absolute; top: 22px; right: 26px; z-index: 3;
    font-family: var(--font-display); font-size: 14px; font-weight: 700;
    letter-spacing: 0.14em; color: var(--violet);
    font-variant-numeric: tabular-nums;
  }
  /* 거대 글리프 — strove식 카드 지배 */
  .card-glyph {
    position: absolute; top: 44%; left: 50%;
    transform: translate(-50%, -50%);
    font-family: var(--font-display); font-weight: 800; line-height: 1;
    font-size: clamp(160px, 42vw, 240px);
    letter-spacing: -0.04em; white-space: nowrap;
    background: linear-gradient(155deg, var(--lav) 0%, var(--violet) 92%);
    -webkit-background-clip: text; background-clip: text;
    color: transparent;
    opacity: 0.92; pointer-events: none; user-select: none;
  }
  .svc-card.is-wide .card-glyph { font-size: clamp(120px, 30vw, 180px); }
  .card-body { position: relative; z-index: 2; }
  .card-cat {
    font-family: var(--font-display); font-size: 11.5px; font-weight: 600;
    letter-spacing: 0.16em; text-transform: uppercase; color: var(--lav);
  }
  .card-title { margin-top: 10px; font-size: clamp(23px, 5.6vw, 32px); font-weight: 600; letter-spacing: -0.03em; line-height: 1.12; }
  .card-desc { margin-top: 10px; color: var(--ink-dim); font-size: 14.5px; line-height: 1.55; max-width: 36ch; }
  .svc-dots { display: none; }

  /* 모바일: 스크롤 진입 시 카드가 3D로 '딜'되며 등장 (JS가 .anim 부여) */
  .svc-card.anim {
    opacity: 0;
    transform: perspective(1000px) rotateX(12deg) translateY(46px);
    transform-origin: center bottom;
    transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1),
      transform 0.9s cubic-bezier(0.22, 1, 0.36, 1);
    will-change: opacity, transform;
  }
  .svc-card.anim.in { opacity: 1; transform: none; }

  /* ── 데스크톱: 스크롤 구동 덱 (큰 카드 1장 중앙 지배 + 다음 카드 살짝 뒤) ── */
  @media (min-width: 880px) and (hover: hover) {
    .svc-3d { height: calc(100vh + (var(--n) - 1) * 62vh); padding: 0; }
    .svc-pin {
      position: sticky; top: 0; height: 100vh; max-width: none; padding-inline: 0;
      overflow: hidden;
    }
    .svc-pin-head {
      position: absolute; top: 0; left: 0; right: 0; z-index: 4;
      padding-top: clamp(34px, 5.5vh, 64px); margin-bottom: 0; pointer-events: none;
    }
    .svc-stage { position: absolute; inset: 0; perspective: 1600px; }
    .svc-deck {
      position: absolute; inset: 0; display: grid; place-items: center;
      transform-style: preserve-3d; gap: 0;
    }
    .svc-card {
      grid-area: 1 / 1;
      width: clamp(340px, 33vw, 500px);
      height: clamp(430px, 66vh, 640px);
      min-height: 0;
      will-change: transform, opacity;
      backface-visibility: hidden;
      transition: border-color 0.4s ease, box-shadow 0.4s ease;
    }
    .card-glyph { font-size: clamp(200px, 15vw, 300px); }
    .svc-card.is-wide .card-glyph { font-size: clamp(150px, 11vw, 220px); }
    .card-title { font-size: clamp(26px, 2vw, 34px); }
    .card-desc { font-size: 15px; }
    .svc-card.focus {
      border-color: rgba(185, 169, 224, 0.5);
      box-shadow: 0 60px 130px -46px rgba(107, 91, 208, 0.6);
    }
    .svc-dots {
      position: absolute; left: 0; right: 0; bottom: clamp(26px, 4.5vh, 48px);
      display: flex; justify-content: center; gap: 10px; z-index: 4;
    }
    .svc-dots span {
      width: 8px; height: 8px; border-radius: 999px;
      background: rgba(185, 169, 224, 0.28);
      transition: background 0.4s ease, width 0.4s ease;
    }
    .svc-dots span.on { width: 26px; background: var(--lav); }
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-card { transition: none; }
  }
</style>

<script>
  const section = document.getElementById('services');
  const deck = document.getElementById('svc-fan');
  if (section && deck) {
    const cards = Array.from(deck.querySelectorAll<HTMLElement>('.svc-card'));
    const dots = Array.from(section.querySelectorAll<HTMLElement>('.svc-dots span'));
    const N = cards.length;
    const mq = matchMedia('(min-width: 880px) and (hover: hover)');
    const reduceMq = matchMedia('(prefers-reduced-motion: reduce)');

    let raf = 0;
    let mode: 'deck' | 'stack' | null = null;
    let io: IntersectionObserver | null = null;

    // 데스크톱: 큰 카드 1장 중앙 + 다음 카드 살짝 뒤·아래 (edge-on 없음)
    const applyDeck = () => {
      raf = 0;
      const rect = section.getBoundingClientRect();
      const total = section.offsetHeight - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      const p = total > 0 ? (scrolled / total) * (N - 1) : 0;
      const focus = Math.round(p);
      for (let i = 0; i < N; i++) {
        const d = i - p;
        let tx, ty, tz, rot, sc, op;
        if (d >= 0) {
          const dc = Math.min(d, 3);
          tx = d * 6; ty = dc * 22; tz = -dc * 92;
          rot = d * 7; sc = 1 - dc * 0.05;
          op = d < 2.4 ? Math.max(0, 1 - d * 0.4) : 0;
        } else {
          tx = 0; ty = d * 48; tz = -50;      // 지나간 카드는 위로 슬라이드
          rot = 0; sc = 1 + d * 0.03;
          op = Math.max(0, 1 + d * 2);         // 빠르게 페이드아웃
        }
        const c = cards[i];
        c.style.transform = `translate3d(${tx}px, ${ty}px, ${tz}px) rotateY(${rot}deg) scale(${sc})`;
        c.style.opacity = String(op);
        c.style.zIndex = String(200 - Math.round(Math.abs(d) * 12));
        c.style.pointerEvents = i === focus ? 'auto' : 'none';
        c.classList.toggle('focus', i === focus);
      }
      dots.forEach((dt, i) => dt.classList.toggle('on', i === focus));
    };
    const clearInline = () => {
      for (const c of cards) {
        c.style.transform = ''; c.style.opacity = ''; c.style.zIndex = '';
        c.style.pointerEvents = ''; c.classList.remove('focus');
      }
      dots.forEach((d) => d.classList.remove('on'));
    };

    const enterDeck = () => {
      mode = 'deck';
      if (io) { io.disconnect(); io = null; }
      cards.forEach((c) => c.classList.remove('anim', 'in'));
      applyDeck();
    };
    const enterStack = () => {
      mode = 'stack';
      clearInline();
      if (reduceMq.matches) { cards.forEach((c) => c.classList.remove('anim')); return; }
      cards.forEach((c) => c.classList.add('anim'));
      io = new IntersectionObserver(
        (entries) => { for (const e of entries) if (e.isIntersecting) { e.target.classList.add('in'); io!.unobserve(e.target); } },
        { threshold: 0.2 }
      );
      cards.forEach((c) => io!.observe(c));
    };

    const chooseMode = () => {
      const wantDeck = mq.matches && !reduceMq.matches;
      if (wantDeck && mode !== 'deck') enterDeck();
      else if (!wantDeck && mode !== 'stack') enterStack();
    };

    const onScroll = () => { if (mode === 'deck' && !raf) raf = requestAnimationFrame(applyDeck); };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', () => { chooseMode(); if (mode === 'deck') applyDeck(); }, { passive: true });
    if (mq.addEventListener) mq.addEventListener('change', chooseMode);
    if (reduceMq.addEventListener) reduceMq.addEventListener('change', chooseMode);
    chooseMode();
    if (mode === 'deck') applyDeck();
  }
</script>
