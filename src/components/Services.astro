---
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

// 각 서비스의 대형 이니셜 글리프 (언어 무관)
const abbr = ['E', 'F', 'A', 'D', 'AX'];
const N = t.services.items.length;
---

<section class="svc-3d" id="services" style={`--n:${N}`}>
  <div class="svc-pin">
    <div class="svc-pin-head">
      <span class="svc-eyebrow">(03)&nbsp;&nbsp;SERVICES</span>
      <h2 class="svc-heading display">{t.services.head}</h2>
    </div>

    <div class="svc-stage">
      <ul class="svc-fan" id="svc-fan">
        {t.services.items.map((s, i) => (
          <li class="svc-card" data-i={i}>
            <span class="card-no">{s.no}</span>
            <span class="card-glyph" aria-hidden="true">{abbr[i]}</span>
            <div class="card-body">
              <h3 class="card-title display">{s.title}</h3>
              <p class="card-desc">{s.desc}</p>
            </div>
          </li>
        ))}
      </ul>
    </div>

    <div class="svc-dots" aria-hidden="true">
      {t.services.items.map((_, i) => <span data-i={i}></span>)}
    </div>
  </div>
</section>

<style>
  /* ── 모바일 우선(정적 스택) — JS/3D 실패해도 안전 ── */
  .svc-3d { position: relative; padding: clamp(60px, 7vw, 100px) 0; }
  .svc-pin { max-width: var(--container); margin-inline: auto; padding-inline: var(--gutter); }
  .svc-pin-head { text-align: center; margin-bottom: clamp(28px, 4vw, 44px); }
  .svc-eyebrow {
    font-family: var(--font-display);
    font-size: 12.5px; font-weight: 500; letter-spacing: 0.22em;
    color: var(--violet); text-transform: uppercase;
  }
  .svc-heading {
    margin-top: 12px;
    font-size: clamp(32px, 5.4vw, 76px);
    font-weight: 600; letter-spacing: -0.05em; line-height: 1.05;
  }
  .svc-fan { list-style: none; display: flex; flex-direction: column; gap: 16px; }
  .svc-card {
    position: relative;
    background: linear-gradient(165deg, #141a3a, #0a0e26);
    border: 1px solid rgba(185, 169, 224, 0.22);
    border-radius: 22px;
    padding: clamp(24px, 3vw, 38px);
    min-height: 200px;
    display: flex; flex-direction: column; justify-content: flex-end;
    overflow: hidden;
    box-shadow: 0 40px 90px -46px rgba(8, 6, 24, 0.9);
  }
  .card-no {
    position: absolute; top: 24px; left: 26px;
    font-family: var(--font-display); font-size: 14px; font-weight: 600;
    letter-spacing: 0.12em; color: var(--violet);
    font-variant-numeric: tabular-nums;
  }
  .card-glyph {
    position: absolute; top: -0.16em; right: 0.04em;
    font-family: var(--font-display);
    font-size: clamp(120px, 15vw, 240px); font-weight: 700; line-height: 1;
    color: transparent; -webkit-text-stroke: 1.5px rgba(185, 169, 224, 0.28);
    pointer-events: none; user-select: none;
  }
  .card-body { position: relative; z-index: 1; }
  .card-title { font-size: clamp(22px, 2vw, 33px); font-weight: 600; letter-spacing: -0.03em; line-height: 1.1; }
  .card-desc { margin-top: 12px; color: var(--ink-dim); font-size: 14.5px; line-height: 1.6; max-width: 34ch; }
  .svc-dots { display: none; }

  /* ── 데스크톱: 스크롤 구동 3D 회전 카드 팬 ── */
  @media (min-width: 880px) and (hover: hover) {
    .svc-3d { height: calc(100vh + (var(--n) - 1) * 46vh); padding: 0; }
    .svc-pin {
      position: sticky; top: 0; height: 100vh; max-width: none; padding-inline: 0;
      overflow: hidden;
    }
    /* 헤딩·닷은 오버레이 → 카드 팬이 뷰포트 전체를 채워 빈 여백 제거 */
    .svc-pin-head {
      position: absolute; top: 0; left: 0; right: 0; z-index: 3;
      padding-top: clamp(34px, 5.5vh, 66px); margin-bottom: 0;
      pointer-events: none;
    }
    .svc-stage { position: absolute; inset: 0; perspective: 1800px; }
    .svc-fan {
      position: absolute; inset: 0; display: grid; place-items: center;
      transform-style: preserve-3d; gap: 0;
    }
    .svc-card {
      grid-area: 1 / 1;
      width: clamp(322px, 30vw, 460px);
      height: clamp(430px, 64vh, 620px);
      min-height: 0;
      will-change: transform, opacity;
      backface-visibility: hidden;
      transition: border-color 0.4s ease, box-shadow 0.4s ease;
    }
    .svc-card.focus {
      border-color: rgba(185, 169, 224, 0.5);
      box-shadow: 0 50px 120px -44px rgba(107, 91, 208, 0.6);
    }
    .card-glyph { font-size: clamp(160px, 13vw, 260px); }
    .svc-dots {
      position: absolute; left: 0; right: 0; bottom: clamp(26px, 4.5vh, 48px);
      display: flex; justify-content: center; gap: 10px; z-index: 3;
    }
    .svc-dots span {
      width: 8px; height: 8px; border-radius: 999px;
      background: rgba(185, 169, 224, 0.28);
      transition: background 0.4s ease, width 0.4s ease;
    }
    .svc-dots span.on { width: 26px; background: var(--lav); }
  }

  @media (prefers-reduced-motion: reduce) {
    .svc-card { transition: none; }
  }
</style>

<script>
  const section = document.getElementById('services');
  const fan = document.getElementById('svc-fan');
  if (section && fan) {
    const cards = Array.from(fan.querySelectorAll<HTMLElement>('.svc-card'));
    const dots = Array.from(section.querySelectorAll<HTMLElement>('.svc-dots span'));
    const N = cards.length;
    const mq = matchMedia('(min-width: 880px) and (hover: hover)');
    const reduceMq = matchMedia('(prefers-reduced-motion: reduce)');

    // 튜닝 파라미터
    const ANGLE = 30;   // deg / step
    const XVW = 15;     // 가로 확산 (vw)
    const YVH = 7;      // 세로 확산 (vh)
    const ZPX = 130;    // 원근 후퇴 (px)

    let raf = 0;
    let wasActive = false;

    const reset = () => {
      for (const c of cards) {
        c.style.transform = ''; c.style.opacity = ''; c.style.zIndex = '';
        c.style.pointerEvents = ''; c.classList.remove('focus');
      }
      dots.forEach((d) => d.classList.remove('on'));
    };

    // 매 프레임 미디어쿼리를 확인 → 자기보정(뷰포트 0/브레이크포인트 전환에도 안전)
    const update = () => {
      raf = 0;
      const active = mq.matches && !reduceMq.matches;
      if (!active) { if (wasActive) { reset(); wasActive = false; } return; }
      wasActive = true;
      const rect = section.getBoundingClientRect();
      const total = section.offsetHeight - window.innerHeight;
      const scrolled = Math.min(Math.max(-rect.top, 0), total);
      const p = total > 0 ? (scrolled / total) * (N - 1) : 0;
      const focus = Math.round(p);
      for (let i = 0; i < N; i++) {
        const d = i - p;
        const ad = Math.abs(d);
        const card = cards[i];
        card.style.transform = `translate3d(${-d * XVW}vw, ${d * YVH}vh, ${-ad * ZPX}px) rotateY(${d * ANGLE}deg)`;
        card.style.opacity = String(Math.max(0.04, 1 - ad * 0.36));
        card.style.zIndex = String(200 - Math.round(ad * 20));
        card.style.pointerEvents = i === focus ? 'auto' : 'none';
        card.classList.toggle('focus', i === focus);
      }
      dots.forEach((dt, i) => dt.classList.toggle('on', i === focus));
    };
    const onScroll = () => { if (!raf) raf = requestAnimationFrame(update); };

    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', update, { passive: true }); // 리사이즈는 즉시 반영
    if (mq.addEventListener) mq.addEventListener('change', update);
    if (reduceMq.addEventListener) reduceMq.addEventListener('change', update);
    update(); // 초기 동기 적용
  }
</script>
