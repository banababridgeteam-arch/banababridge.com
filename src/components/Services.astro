---
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section" id="services">
  <div class="container">
    <p class="index-label reveal"><span class="num">03</span><span class="txt">{t.services.label}</span></p>
    <h2 class="display h-lg reveal">{t.services.head}</h2>

    <ol class="svc-list">
      {t.services.items.map((s) => (
        <li class="svc-row reveal">
          <span class="svc-no">{s.no}</span>
          <span class="svc-title display">{s.title}</span>
          <span class="svc-desc">{s.desc}</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .svc-list { list-style: none; margin-top: clamp(36px, 5vw, 64px); border-top: 1px solid var(--line); }
  .svc-row {
    display: grid;
    grid-template-columns: 64px 1fr minmax(0, 34ch);
    align-items: center;
    gap: 24px;
    padding: clamp(24px, 3.4vw, 40px) 0;
    border-bottom: 1px solid var(--line);
    transition: padding-left 0.35s cubic-bezier(0.22,1,0.36,1);
  }
  .svc-row:hover { padding-left: 14px; }
  .svc-no { font-size: 14px; font-weight: 500; color: var(--gold); font-variant-numeric: tabular-nums; }
  .svc-title { font-size: clamp(22px, 3vw, 40px); font-weight: 600; letter-spacing: -0.03em; line-height: 1.1; }
  .svc-desc { color: var(--muted); font-size: 14.5px; line-height: 1.55; }

  @media (max-width: 820px) {
    .svc-row { grid-template-columns: 40px 1fr; row-gap: 10px; align-items: baseline; }
    .svc-desc { grid-column: 2; }
  }
</style>
