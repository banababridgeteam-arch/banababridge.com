---
import SectionHead from './SectionHead.astro';
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

// 각 서비스의 대형 이니셜 마크 (언어 무관)
const abbr = ['E', 'F', 'A', 'D', 'AX'];
---

<section class="section" id="services">
  <div class="container">
    <SectionHead num="03" text={t.services.head} />

    <ol class="svc-list">
      {t.services.items.map((s, i) => (
        <li class="svc-row reveal">
          <span class="svc-no">{s.no}</span>
          <div class="svc-main">
            <h3 class="svc-title display">{s.title}</h3>
            <p class="svc-desc">{s.desc}</p>
          </div>
          <span class="svc-abbr display" aria-hidden="true">{abbr[i]}</span>
          <span class="svc-arrow" aria-hidden="true">→</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .svc-list {
    list-style: none;
    margin-top: clamp(40px, 5vw, 72px);
    border-top: 1px solid var(--line);
  }
  .svc-row {
    position: relative;
    display: grid;
    grid-template-columns: 60px minmax(0, 1fr) auto 44px;
    align-items: center;
    gap: clamp(20px, 3vw, 48px);
    padding: clamp(28px, 3.6vw, 52px) 0;
    border-bottom: 1px solid var(--line);
    transition: padding-left 0.4s cubic-bezier(0.22, 1, 0.36, 1), background 0.4s ease;
  }
  .svc-row::before {
    content: '';
    position: absolute;
    left: -100vw; right: -100vw; top: 0; bottom: 0;
    background: linear-gradient(180deg, rgba(201, 162, 94, 0.06), transparent);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  .svc-row:hover::before { opacity: 1; }
  .svc-row:hover { padding-left: 16px; }

  .svc-no {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 500;
    color: var(--gold);
    font-variant-numeric: tabular-nums;
    align-self: start;
    padding-top: 0.35em;
  }
  .svc-title { font-size: clamp(24px, 3.2vw, 44px); font-weight: 600; letter-spacing: -0.04em; line-height: 1.05; }
  .svc-desc { margin-top: 12px; max-width: 48ch; color: var(--ink-dim); font-size: clamp(14.5px, 1.4vw, 16px); line-height: 1.6; }

  /* 대형 이니셜 — 골드 아웃라인 워터마크 */
  .svc-abbr {
    justify-self: end;
    font-size: clamp(48px, 6.5vw, 104px);
    font-weight: 700;
    letter-spacing: -0.04em;
    line-height: 1;
    color: transparent;
    -webkit-text-stroke: 1.4px rgba(201, 162, 94, 0.55);
    transition: -webkit-text-stroke-color 0.4s ease, color 0.4s ease;
  }
  .svc-row:hover .svc-abbr {
    color: transparent;
    -webkit-text-stroke-color: var(--gold);
  }

  .svc-arrow {
    justify-self: end;
    font-size: 22px;
    color: var(--gold);
    opacity: 0;
    transform: translateX(-8px);
    transition: opacity 0.4s ease, transform 0.4s ease;
  }
  .svc-row:hover .svc-arrow { opacity: 1; transform: none; }

  @media (max-width: 860px) {
    .svc-row {
      grid-template-columns: 40px 1fr;
      row-gap: 10px;
      align-items: baseline;
    }
    .svc-desc { grid-column: 2; }
    .svc-abbr { display: none; }
    .svc-arrow { display: none; }
  }
</style>
