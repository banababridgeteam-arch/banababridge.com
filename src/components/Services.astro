---
const services = [
  {
    tag: 'ENTERTAINMENT',
    title: '엔터테인먼트 에이전시',
    desc: 'K-아티스트의 글로벌 무대를 처음부터 끝까지 만듭니다.',
    items: [
      '해외 팬미팅 · 팬콘서트 기획 및 에이전시',
      '아티스트 섭외 · 출연 계약 대행',
      '브랜드 광고 · 앰버서더 에이전시',
      '비자 · 스태프 · 현지 운영 코디네이션',
    ],
  },
  {
    tag: 'VENDOR / DISTRIBUTION',
    title: '브랜드 유통 벤더',
    desc: '좋은 브랜드를 찾아 팔리는 채널에 연결합니다.',
    items: [
      '브랜드 소싱 · 머천다이징(MD)',
      '국내외 판매 채널 연결',
      '공급 · 정산 · 물류 조율',
      '카테고리: 아이웨어 · 패션 · 뷰티 · F&B',
    ],
  },
];
---

<section class="section" id="services">
  <div class="container">
    <p class="eyebrow reveal">Services</p>
    <h2 class="h2 reveal">두 개의 다리를 놓습니다.</h2>
    <p class="lead reveal">
      엔터테인먼트와 유통. 서로 다른 두 사업이지만 하는 일은 같습니다 —
      가치가 필요한 곳으로 가치를 건너가게 하는 것.
    </p>

    <div class="svc-grid">
      {services.map((s) => (
        <article class="card svc-card reveal">
          <p class="svc-tag">{s.tag}</p>
          <h3>{s.title}</h3>
          <p class="svc-desc">{s.desc}</p>
          <ul>
            {s.items.map((item) => <li>{item}</li>)}
          </ul>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .svc-grid {
    margin-top: 52px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(300px, 100%), 1fr));
    gap: 22px;
  }
  .svc-card { padding: 38px 34px; }
  .svc-tag {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.2em;
    color: var(--gold);
  }
  .svc-card h3 {
    margin-top: 14px;
    font-size: clamp(21px, 2.4vw, 25px);
    letter-spacing: -0.02em;
  }
  .svc-desc { margin-top: 10px; color: var(--ink-dim); font-size: 15.5px; }
  .svc-card ul {
    margin-top: 22px;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 11px;
  }
  .svc-card li {
    position: relative;
    padding-left: 22px;
    color: var(--ink-dim);
    font-size: 15px;
  }
  .svc-card li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.62em;
    width: 10px;
    height: 1.5px;
    background: var(--gold);
  }
</style>
