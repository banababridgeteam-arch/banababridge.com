---
import { SITE } from '../config';
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<div class="callbar" role="complementary" aria-label={t.cta.inquire}>
  {SITE.phone && (
    <a class="callbar-btn call" href={`tel:${SITE.phone}`}>
      <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/>
      </svg>
      {t.cta.call}
    </a>
  )}
  <a class={`callbar-btn ${SITE.phone ? 'mail' : 'call'}`} href={`mailto:${SITE.email}`}>
    <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
      <rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/>
    </svg>
    {t.cta.email}
  </a>
</div>

<style>
  .callbar {
    display: none;
    position: fixed;
    inset: auto 0 0 0;
    z-index: 90;
    padding: 10px 14px calc(10px + env(safe-area-inset-bottom));
    gap: 10px;
    background: rgba(7, 11, 28, 0.94);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border-top: 1px solid var(--line);
  }
  .callbar-btn {
    flex: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 13px 0;
    border-radius: 10px;
    font-size: 14.5px;
    font-weight: 400;
  }
  .call { background: linear-gradient(135deg, var(--rose), var(--lav)); color: var(--ink-on-accent); }
  .mail { border: 1px solid var(--line-strong); color: var(--ink); }
  @media (max-width: 768px) { .callbar { display: flex; } body { padding-bottom: 74px; } }
</style>
