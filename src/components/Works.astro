---
import { Image, getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { works } from '../data/works';
import sundriesLogo from '../assets/brand/sundries-logo.png';
import SectionHead from './SectionHead.astro';
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const igImages = import.meta.glob<{ default: ImageMetadata }>('../assets/ig/*.jpg', { eager: true });
const findImage = (name?: string) =>
  name ? (Object.entries(igImages).find(([p]) => p.endsWith(name))?.[1].default ?? null) : null;

const statusText = (k?: string) =>
  k === 'ongoing' ? t.work.ongoing : k === 'upcoming' ? t.work.upcoming : k === 'comingSoon' ? t.work.comingSoon : null;

const resolve = async (meta: ImageMetadata | null) =>
  meta ? (await getImage({ src: meta, width: 560 })).src : null;

const featured = works.find((w) => w.featured);
const featuredImg = findImage(featured?.image);
const rest = works.filter((w) => !w.featured);

// 호버 리빌·모바일 썸네일용 이미지 URL 미리 해결
const rows = await Promise.all(
  rest.map(async (w) => ({
    w,
    st: statusText(w.statusKey),
    imgSrc: w.image ? await resolve(findImage(w.image)) : w.brandLogo ? await resolve(sundriesLogo) : null,
  }))
);
---

<section class="section" id="work">
  <div class="container">
    <SectionHead num="02" text={t.work.head} />

    {featured && (
      <article class="featured reveal">
        <div class="featured-media">
          <video controls playsinline preload="none" poster={featuredImg?.src} aria-label={featured.title[lang]}>
            <source src={featured.video} type="video/mp4" />
          </video>
        </div>
        <div class="featured-body">
          <p class="feat-tag">{t.work.featured} · {featured.category}</p>
          <h3 class="display">{featured.title[lang]}</h3>
          <div class="feat-meta">
            <span>{featured.year}</span>
            {featured.location && <span class="loc">{featured.location}</span>}
          </div>
          {featured.link && (
            <a class="feat-ig" href={featured.link} target="_blank" rel="noopener">Instagram ↗</a>
          )}
        </div>
      </article>
    )}

    {/* strove식 프로젝트 인덱스 — 호버 시 커서 옆에 이미지 리빌 */}
    <div class="work-index" id="work-index">
      {rows.map(({ w, st, imgSrc }) => {
        const Tag = w.link ? 'a' : 'div';
        const linkAttrs = w.link ? { href: w.link, target: '_blank', rel: 'noopener' } : {};
        return (
          <Tag class="work-row reveal" data-img={imgSrc} {...linkAttrs}>
            <span class="wr-no">{w.index}</span>
            {imgSrc && <img class="wr-thumb" src={imgSrc} alt="" width="120" height="150" loading="lazy" decoding="async" />}
            <span class="wr-title">{w.title[lang]}</span>
            <span class="wr-meta">
              {w.year}{w.location ? ` · ${w.location}` : ''}{st ? ` · ${st}` : ''}
            </span>
            <span class="wr-go" aria-hidden="true">{w.link ? '↗' : ''}</span>
          </Tag>
        );
      })}
    </div>
  </div>

  {/* 커서 추적 리빌 이미지 (데스크톱) */}
  <div class="work-peek" id="work-peek" aria-hidden="true"><img alt="" decoding="async" /></div>
</section>

<style>
  /* 피처드 (티파니 홍콩 영상) */
  .featured {
    margin-top: clamp(36px, 5vw, 64px);
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(260px, 1fr);
    gap: clamp(24px, 3vw, 48px);
    align-items: center;
  }
  .featured-media video {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: #000;
  }
  .feat-tag { font-size: 12px; font-weight: 600; letter-spacing: 0.16em; color: var(--gold); }
  .featured-body h3 { margin-top: 16px; font-size: clamp(30px, 4.4vw, 60px); font-weight: 600; letter-spacing: -0.045em; line-height: 1.08; }
  .feat-meta { margin-top: 22px; display: flex; gap: 18px; font-size: 13.5px; color: var(--muted); letter-spacing: 0.05em; }
  .feat-meta .loc { color: var(--gold-soft); }
  .feat-ig {
    display: inline-block;
    margin-top: 22px;
    padding: 10px 20px;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--ink);
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .feat-ig:hover { border-color: var(--gold); color: var(--gold-soft); }

  /* 프로젝트 인덱스 */
  .work-index {
    margin-top: clamp(44px, 6vw, 88px);
    border-top: 1px solid var(--line);
  }
  .work-row {
    position: relative;
    display: grid;
    grid-template-columns: 54px minmax(0, 1fr) minmax(0, 240px) 34px;
    align-items: center;
    gap: 20px;
    padding: clamp(22px, 2.8vw, 38px) 0;
    border-bottom: 1px solid var(--line);
    color: inherit;
    transition: padding-left 0.4s cubic-bezier(0.22,1,0.36,1), color 0.3s ease;
  }
  a.work-row:hover { padding-left: 16px; }
  .wr-no { font-family: var(--font-display); font-size: 15px; font-weight: 600; color: var(--gold); }
  .wr-title {
    font-family: var(--font-display);
    font-size: clamp(21px, 2.9vw, 40px);
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.05;
    transition: color 0.3s ease;
  }
  a.work-row:hover .wr-title { color: var(--gold-soft); }
  .wr-meta { font-size: 13px; color: var(--muted); letter-spacing: 0.03em; white-space: normal; text-align: right; }
  .wr-go { justify-self: end; font-size: 18px; color: var(--gold); opacity: 0.5; transition: opacity 0.3s ease, transform 0.3s ease; }
  a.work-row:hover .wr-go { opacity: 1; transform: translate(3px, -3px); }
  .wr-thumb { display: none; }

  /* 커서 추적 리빌 이미지 */
  .work-peek {
    position: fixed;
    top: 0; left: 0;
    width: clamp(220px, 22vw, 360px);
    aspect-ratio: 4 / 5;
    border-radius: 14px;
    overflow: hidden;
    border: 1px solid var(--line-strong);
    box-shadow: 0 40px 90px -40px rgba(0,0,0,0.9);
    pointer-events: none;
    z-index: 60;
    opacity: 0;
    transform: translate(-50%, -50%) scale(0.92) rotate(-3deg);
    transition: opacity 0.35s ease, transform 0.45s cubic-bezier(0.22,1,0.36,1);
    will-change: transform;
  }
  .work-peek.show { opacity: 1; transform: translate(-50%, -50%) scale(1) rotate(0deg); }
  .work-peek img { width: 100%; height: 100%; object-fit: cover; display: block; }

  /* 모바일·터치: 리빌 대신 인라인 썸네일 */
  @media (hover: none), (max-width: 860px) {
    .work-peek { display: none; }
    .work-row {
      grid-template-columns: 64px 1fr 22px;
      grid-template-areas: 'thumb title go' 'thumb meta go';
      row-gap: 6px;
      column-gap: 16px;
    }
    .wr-no { display: none; }
    .wr-thumb {
      display: block;
      grid-area: thumb;
      width: 64px; height: 80px;
      object-fit: cover;
      border-radius: 8px;
      border: 1px solid var(--line);
    }
    .wr-title { grid-area: title; font-size: 18px; }
    .wr-meta { grid-area: meta; white-space: normal; }
    .wr-go { grid-area: go; align-self: center; }
  }

  @media (max-width: 860px) {
    .featured { grid-template-columns: 1fr; }
    .featured-media video { aspect-ratio: 16 / 11; }
  }
</style>

<script>
  // 커서 추적 hover-reveal (데스크톱 · hover 가능 기기)
  const peek = document.getElementById('work-peek');
  const peekImg = peek?.querySelector('img') as HTMLImageElement | null;
  const rows = Array.from(document.querySelectorAll<HTMLElement>('#work-index .work-row[data-img]'));
  const fine = matchMedia('(hover: hover) and (pointer: fine)').matches;

  if (peek && peekImg && rows.length && fine) {
    let tx = innerWidth / 2, ty = innerHeight / 2, x = tx, y = ty, raf = 0, active = false;

    const loop = () => {
      x += (tx - x) * 0.16;
      y += (ty - y) * 0.16;
      peek.style.transform =
        `translate(${x}px, ${y}px) translate(-50%, -50%) scale(${active ? 1 : 0.92}) rotate(${active ? 0 : -3}deg)`;
      if (active || Math.abs(tx - x) > 0.5 || Math.abs(ty - y) > 0.5) {
        raf = requestAnimationFrame(loop);
      } else { raf = 0; }
    };
    const kick = () => { if (!raf) raf = requestAnimationFrame(loop); };

    addEventListener('mousemove', (e) => { tx = e.clientX; ty = e.clientY; if (active) kick(); }, { passive: true });

    rows.forEach((row) => {
      const src = row.dataset.img!;
      row.addEventListener('mouseenter', () => {
        if (peekImg.getAttribute('src') !== src) peekImg.src = src;
        active = true;
        peek.classList.add('show');
        kick();
      });
      row.addEventListener('mouseleave', () => {
        active = false;
        peek.classList.remove('show');
        kick();
      });
    });
  }
</script>
