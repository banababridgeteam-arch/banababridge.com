---
import { works } from '../data/works';
---

<section class="section" id="works">
  <div class="container">
    <p class="eyebrow reveal">References</p>
    <h2 class="h2 reveal">말이 아니라, 기록으로 증명합니다.</h2>
    <p class="lead reveal">
      홈페이지에 올린다는 것은 공적으로 책임진다는 뜻입니다.
      바나바브릿지는 실제로 진행한 프로젝트만 기록합니다.
    </p>

    <div class="works-grid">
      {works.map((w) => (
        <article class="card work-card reveal">
          <div class="work-head">
            <span class="work-index">{w.index}</span>
            <span class="work-cat">{w.category}</span>
          </div>
          <h3>{w.title}</h3>
          <p>{w.desc}</p>
          <div class="work-meta">
            <span>{w.year}</span>
            {w.status && <span class="work-status">{w.status}</span>}
          </div>
        </article>
      ))}
    </div>
  </div>
</section>

<style>
  .works-grid {
    margin-top: 52px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: 20px;
  }
  .work-card {
    padding: 30px 28px;
    display: flex;
    flex-direction: column;
  }
  .work-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .work-index {
    font-size: 15px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.08em;
  }
  .work-cat {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--muted);
  }
  .work-card h3 {
    margin-top: 20px;
    font-size: 17.5px;
    line-height: 1.45;
    letter-spacing: -0.01em;
  }
  .work-card p {
    margin-top: 10px;
    color: var(--muted);
    font-size: 14px;
    flex: 1;
  }
  .work-meta {
    margin-top: 22px;
    padding-top: 16px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    font-size: 13px;
    color: var(--ink-dim);
  }
  .work-status { color: var(--gold); font-weight: 600; }
</style>
