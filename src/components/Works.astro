---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { works } from '../data/works';
import sundriesLogo from '../assets/brand/sundries-logo.png';
import SectionHead from './SectionHead.astro';
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);

const igImages = import.meta.glob<{ default: ImageMetadata }>('../assets/ig/*.jpg', { eager: true });
const findImage = (name?: string) =>
  name ? (Object.entries(igImages).find(([p]) => p.endsWith(name))?.[1].default ?? null) : null;

const statusText = (k?: string) =>
  k === 'ongoing' ? t.work.ongoing : k === 'upcoming' ? t.work.upcoming : k === 'comingSoon' ? t.work.comingSoon : null;

const featured = works.find((w) => w.featured);
const featuredImg = findImage(featured?.image);
const rest = works.filter((w) => !w.featured);
---

<section class="section" id="work">
  <div class="container">
    <SectionHead num="02" text={t.work.head} />

    {featured && (
      <article class="featured reveal">
        <div class="featured-media">
          <video controls playsinline preload="none" poster={featuredImg?.src} aria-label={featured.title[lang]}>
            <source src={featured.video} type="video/mp4" />
          </video>
        </div>
        <div class="featured-body">
          <p class="feat-tag">{t.work.featured} · {featured.category}</p>
          <h3 class="display">{featured.title[lang]}</h3>
          <div class="feat-meta">
            <span>{featured.year}</span>
            {featured.location && <span class="loc">{featured.location}</span>}
          </div>
          {featured.link && (
            <a class="feat-ig" href={featured.link} target="_blank" rel="noopener">Instagram ↗</a>
          )}
        </div>
      </article>
    )}

    <div class="work-grid">
      {rest.map((w) => {
        const img = findImage(w.image);
        const st = statusText(w.statusKey);
        const Tag = w.link ? 'a' : 'div';
        const linkAttrs = w.link ? { href: w.link, target: '_blank', rel: 'noopener' } : {};
        return (
          <Tag class="work-card reveal" {...linkAttrs}>
            {img ? (
              <div class="wc-media">
                <Image src={img} alt={w.title[lang]} width={720} loading="lazy" />
                {w.link && <span class="wc-go" aria-hidden="true">↗</span>}
              </div>
            ) : (
              <div class="wc-media brand">
                <Image src={sundriesLogo} alt={w.title[lang]} width={440} loading="lazy" />
              </div>
            )}
            <div class="wc-body">
              <span class="wc-cat">{w.category}</span>
              <h3>{w.title[lang]}</h3>
              <div class="wc-meta">
                <span>{w.year}</span>
                {st && <span class="wc-status">{st}</span>}
              </div>
            </div>
          </Tag>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* 피처드 (티파니 홍콩 영상) */
  .featured {
    margin-top: clamp(36px, 5vw, 64px);
    display: grid;
    grid-template-columns: minmax(0, 1.5fr) minmax(260px, 1fr);
    gap: clamp(24px, 3vw, 48px);
    align-items: center;
  }
  .featured-media video {
    width: 100%;
    aspect-ratio: 16 / 10;
    object-fit: cover;
    border-radius: 16px;
    border: 1px solid var(--line);
    background: #000;
  }
  .feat-tag { font-size: 12px; font-weight: 600; letter-spacing: 0.16em; color: var(--gold); }
  .featured-body h3 { margin-top: 16px; font-size: clamp(24px, 3.2vw, 40px); font-weight: 600; letter-spacing: -0.03em; line-height: 1.12; }
  .feat-meta { margin-top: 22px; display: flex; gap: 18px; font-size: 13.5px; color: var(--muted); letter-spacing: 0.05em; }
  .feat-meta .loc { color: var(--gold-soft); }
  .feat-ig {
    display: inline-block;
    margin-top: 22px;
    padding: 10px 20px;
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    font-size: 13.5px;
    font-weight: 500;
    color: var(--ink);
    transition: border-color 0.25s ease, color 0.25s ease;
  }
  .feat-ig:hover { border-color: var(--gold); color: var(--gold-soft); }

  /* 그리드 카드 */
  .work-grid {
    margin-top: clamp(40px, 6vw, 80px);
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
    gap: clamp(20px, 2.4vw, 36px);
  }
  .work-card { display: flex; flex-direction: column; }
  a.work-card { color: inherit; }
  .wc-media {
    position: relative;
    aspect-ratio: 4 / 5;
    overflow: hidden;
    border-radius: 14px;
    border: 1px solid var(--line);
    background: var(--bg-3);
  }
  .wc-go {
    position: absolute;
    top: 12px; right: 12px;
    width: 34px; height: 34px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 50%;
    background: rgba(0,0,0,0.5);
    backdrop-filter: blur(6px);
    color: var(--gold-soft);
    font-size: 15px;
    opacity: 0;
    transform: translateY(-6px);
    transition: opacity 0.3s ease, transform 0.3s ease;
  }
  .work-card:hover .wc-go { opacity: 1; transform: none; }
  .wc-media :global(img) {
    width: 100%; height: 100%; object-fit: cover; display: block;
    transition: transform 0.7s cubic-bezier(0.22,1,0.36,1);
  }
  .work-card:hover .wc-media :global(img) { transform: scale(1.05); }
  .wc-media.brand {
    display: flex; align-items: center; justify-content: center; padding: 16%;
    background: radial-gradient(80% 80% at 50% 20%, rgba(201,162,94,0.14), transparent 65%), linear-gradient(180deg,#101013,#050506);
  }
  .wc-media.brand :global(img) { width: 100%; height: auto; object-fit: contain; transition: none; }

  .wc-body { padding-top: 18px; }
  .wc-cat { font-size: 11px; font-weight: 600; letter-spacing: 0.16em; color: var(--muted); }
  .wc-body h3 { margin-top: 10px; font-size: 17px; font-weight: 500; letter-spacing: -0.01em; line-height: 1.4; }
  .wc-meta { margin-top: 14px; display: flex; justify-content: space-between; font-size: 12.5px; color: var(--ink-dim); }
  .wc-status { color: var(--gold); font-weight: 600; }

  @media (max-width: 820px) {
    .featured { grid-template-columns: 1fr; }
    .featured-media video { aspect-ratio: 16 / 11; }
  }
</style>
