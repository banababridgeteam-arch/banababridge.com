---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import { works } from '../data/works';
import sundriesLogo from '../assets/brand/sundries-logo.png';

// src/assets/ig/ 이미지 자동 매칭 (works.ts 의 image 파일명 기준)
const igImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/ig/*.jpg',
  { eager: true }
);
const findImage = (name?: string) => {
  if (!name) return null;
  const hit = Object.entries(igImages).find(([path]) => path.endsWith(name));
  return hit ? hit[1].default : null;
};

const featured = works.find((w) => w.featured);
const featuredImg = findImage(featured?.image);
const rest = works.filter((w) => !w.featured);
---

<section class="section" id="works">
  <div class="container">
    <p class="eyebrow reveal">References</p>
    <h2 class="h2 reveal">말이 아니라, 기록으로 증명합니다.</h2>
    <p class="lead reveal">
      홈페이지에 올린다는 것은 공적으로 책임진다는 뜻입니다.
      바나바브릿지는 실제로 진행한 프로젝트만 기록합니다.
    </p>

    {featured && (
      <article class="featured-card reveal">
        <div class="featured-media">
          <video
            controls
            playsinline
            preload="none"
            poster={featuredImg?.src}
            aria-label={`${featured.title} 현장 영상`}
          >
            <source src={featured.video} type="video/mp4" />
          </video>
        </div>
        <div class="featured-body">
          <p class="feat-label">FEATURED · {featured.category}</p>
          <h3>{featured.title}</h3>
          <p class="feat-desc">{featured.desc}</p>
          <div class="feat-meta">
            <span>{featured.year}</span>
            <span class="feat-loc">HONG KONG</span>
          </div>
        </div>
      </article>
    )}

    <div class="works-grid">
      {rest.map((w) => {
        const img = findImage(w.image);
        return (
          <article class="card work-card reveal">
            {img ? (
              <div class="work-media">
                <Image
                  src={img}
                  alt={`${w.title} — 바나바브릿지 진행`}
                  width={640}
                  loading="lazy"
                />
              </div>
            ) : w.brandLogo ? (
              <div class="work-media brand-media">
                <Image
                  src={sundriesLogo}
                  alt="SUNDRIES Archive 로고"
                  width={420}
                  loading="lazy"
                />
              </div>
            ) : (
              <div class="work-media ghost-media" aria-hidden="true">
                <svg viewBox="0 0 120 40" fill="none">
                  <path d="M8 32 Q60 6 112 32" stroke="#cfa96b" stroke-width="1.4" opacity="0.7" />
                  <circle cx="8" cy="32" r="2.6" fill="#cfa96b" />
                  <circle cx="112" cy="32" r="2.6" fill="#cfa96b" />
                </svg>
              </div>
            )}
            <div class="work-body">
              <div class="work-head">
                <span class="work-index">{w.index}</span>
                <span class="work-cat">{w.category}</span>
              </div>
              <h3>{w.title}</h3>
              <p>{w.desc}</p>
              <div class="work-meta">
                <span>{w.year}</span>
                {w.status && <span class="work-status">{w.status}</span>}
              </div>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  /* ---------- 피처드 (티파니 홍콩 영상) ---------- */
  .featured-card {
    margin-top: 52px;
    display: grid;
    grid-template-columns: minmax(280px, 400px) 1fr;
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
    padding: clamp(24px, 3.5vw, 44px);
    border: 1px solid rgba(207, 169, 107, 0.35);
    border-radius: 20px;
    background:
      radial-gradient(90% 130% at 90% 0%, rgba(207, 169, 107, 0.12), transparent 55%),
      linear-gradient(180deg, var(--bg-2), var(--bg-3));
  }
  .featured-media video {
    width: 100%;
    max-height: 560px;
    border-radius: 14px;
    background: #000;
    display: block;
  }
  .feat-label {
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 0.22em;
    color: var(--gold);
  }
  .featured-body h3 {
    margin-top: 14px;
    font-size: clamp(22px, 3vw, 32px);
    line-height: 1.3;
    letter-spacing: -0.02em;
  }
  .feat-desc {
    margin-top: 14px;
    max-width: 480px;
    color: var(--ink-dim);
    font-size: 15.5px;
  }
  .feat-meta {
    margin-top: 26px;
    display: flex;
    gap: 18px;
    font-size: 13.5px;
    color: var(--muted);
    letter-spacing: 0.06em;
  }
  .feat-loc { color: var(--gold-soft); font-weight: 600; }

  /* ---------- 일반 카드 ---------- */
  .works-grid {
    margin-top: 22px;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(min(260px, 100%), 1fr));
    gap: 20px;
  }
  .work-card {
    overflow: hidden;
    display: flex;
    flex-direction: column;
    padding: 0;
  }
  .work-media {
    aspect-ratio: 4 / 5;
    overflow: hidden;
    background: var(--bg-3);
  }
  .work-media :global(img) {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s cubic-bezier(0.22, 1, 0.36, 1);
  }
  .work-card:hover .work-media :global(img) { transform: scale(1.045); }

  .brand-media {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 15%;
    background:
      radial-gradient(80% 80% at 50% 20%, rgba(207, 169, 107, 0.14), transparent 65%),
      linear-gradient(180deg, #14141c, #0d0d13);
  }
  .brand-media :global(img) {
    width: 100%;
    height: auto;
    object-fit: contain;
  }
  .ghost-media {
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 18%;
    background:
      radial-gradient(80% 80% at 50% 25%, rgba(207, 169, 107, 0.1), transparent 65%),
      linear-gradient(180deg, #13131b, #0d0d13);
  }
  .ghost-media svg { width: 70%; }

  .work-body {
    padding: 24px 24px 26px;
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .work-head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
  }
  .work-index {
    font-size: 14px;
    font-weight: 700;
    color: var(--gold);
    letter-spacing: 0.08em;
  }
  .work-cat {
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.16em;
    color: var(--muted);
  }
  .work-body h3 {
    margin-top: 14px;
    font-size: 16.5px;
    line-height: 1.45;
    letter-spacing: -0.01em;
  }
  .work-body > p {
    margin-top: 9px;
    color: var(--muted);
    font-size: 13.5px;
    flex: 1;
  }
  .work-meta {
    margin-top: 18px;
    padding-top: 14px;
    border-top: 1px solid var(--line);
    display: flex;
    justify-content: space-between;
    font-size: 12.5px;
    color: var(--ink-dim);
  }
  .work-status { color: var(--gold); font-weight: 600; }

  @media (max-width: 820px) {
    .featured-card { grid-template-columns: 1fr; }
    .featured-media video { max-height: 480px; margin-inline: auto; }
  }
</style>
