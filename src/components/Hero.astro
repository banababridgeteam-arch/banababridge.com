---
import { Image } from 'astro:assets';
import { SITE } from '../config';
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
import heroImg from '../assets/brand/hero-connection.png';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero" id="top">
  <Image class="hero-img" src={heroImg} alt="" width={1600} fetchpriority="high" loading="eager" />
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="container hero-inner">
    <div class="hero-top">
      <p class="hero-badge reveal">{t.hero.badge}</p>

      <h1 class="hero-title reveal mask-head">
        <span class="ml"><span>{t.hero.line1}</span></span>
        <span class="ml"><span>{t.hero.line2}</span></span>
      </h1>

      <p class="hero-recent reveal">
        <span class="recent-label">{t.hero.recent}</span>
        <span class="typing" id="typing" data-words={JSON.stringify(t.hero.rotate)}></span><span class="caret" aria-hidden="true"></span>
      </p>

      <div class="hero-cta reveal">
        {SITE.phone ? (
          <a class="btn btn-gold" href={`tel:${SITE.phone}`}>{t.cta.call}</a>
        ) : (
          <a class="btn btn-gold" href={`mailto:${SITE.email}`}>{t.cta.inquire}</a>
        )}
        <a class="btn btn-ghost" href="#work">{t.nav.work}</a>
      </div>
    </div>

    <div class="hero-wordmark" aria-hidden="true">BANABA BRIDGE<span>®</span></div>
  </div>

  <span class="scroll-tag" aria-hidden="true">{t.hero.scroll}</span>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    overflow: hidden;
    background: #000;
  }
  .hero-img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: 0.9;
  }
  .hero-overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(180deg, rgba(0,0,0,0.72) 0%, rgba(0,0,0,0.28) 38%, rgba(0,0,0,0.55) 68%, rgba(0,0,0,0.96) 100%),
      radial-gradient(60% 60% at 20% 30%, rgba(0,0,0,0.5), transparent 70%);
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    width: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding-top: calc(var(--header-h) + 42px);
    padding-bottom: clamp(6px, 3vw, 30px);
  }

  .hero-badge {
    font-size: 12.5px;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .hero-title {
    margin-top: 20px;
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(34px, 4.8vw, 72px); /* strove hero = 70px */
    line-height: 1.1;
    letter-spacing: -0.06em;
    max-width: 13ch;
  }
  .hero-title .ml:last-child > span { color: var(--ink-dim); }

  .hero-recent {
    margin-top: 22px;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 8px 14px;
    font-family: var(--font-display);
    font-size: clamp(15px, 1.7vw, 19px);
  }
  .recent-label {
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink-dim);
    border: 1px solid var(--line-strong);
    border-radius: 999px;
    padding: 4px 11px;
  }
  .typing { color: var(--gold-soft); font-weight: 500; min-height: 1em; }
  .caret {
    display: inline-block;
    width: 2px; height: 1.05em;
    margin-left: 2px;
    background: var(--gold);
    transform: translateY(3px);
    animation: blink 1s steps(1) infinite;
  }
  @keyframes blink { 50% { opacity: 0; } }

  .hero-cta { margin-top: 32px; display: flex; gap: 14px; flex-wrap: wrap; }

  /* 하단 거대 워드마크 (strove 시그니처) */
  .hero-wordmark {
    margin-top: clamp(48px, 8vw, 100px);
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(40px, 12.6vw, 250px);
    line-height: 0.86;
    letter-spacing: -0.055em;
    white-space: nowrap;
    color: var(--ink);
    opacity: 0.97;
  }
  .hero-wordmark span { color: var(--gold); font-size: 0.28em; vertical-align: top; }

  .scroll-tag {
    position: absolute;
    bottom: 26px;
    right: var(--gutter);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--ink-dim);
    z-index: 3;
  }
  @media (max-width: 640px) {
    .hero-wordmark { font-size: 15vw; white-space: normal; }
    .scroll-tag { display: none; }
  }
  @media (prefers-reduced-motion: reduce) { .caret { animation: none; } }
</style>

<script>
  // 타이핑 애니메이션 — 최근 진행 프로젝트 순환
  const el = document.getElementById('typing');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (el && el.dataset.words) {
    let words: string[] = [];
    try { words = JSON.parse(el.dataset.words); } catch {}
    if (words.length) {
      if (reduce) { el.textContent = words[0]; }
      else {
        let wi = 0, ci = 0, deleting = false;
        const tick = () => {
          const word = words[wi];
          if (!deleting) {
            ci++; el.textContent = word.slice(0, ci);
            if (ci === word.length) { deleting = true; return setTimeout(tick, 1600); }
          } else {
            ci--; el.textContent = word.slice(0, ci);
            if (ci === 0) { deleting = false; wi = (wi + 1) % words.length; }
          }
          setTimeout(tick, deleting ? 34 : 68);
        };
        setTimeout(tick, 700);
      }
    }
  }
</script>
