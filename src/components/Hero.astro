---
import { SITE } from '../config';
---

<section class="hero" id="top">
  <canvas id="bridge-canvas" aria-hidden="true"></canvas>
  <div class="hero-glow" aria-hidden="true"></div>

  <div class="container hero-inner">
    <p class="eyebrow">Entertainment Agency &amp; Global Vendor</p>
    <h1>
      아티스트에겐 <em>무대</em>를,<br />
      브랜드에겐 <em>시장</em>을.
    </h1>
    <p class="hero-sub">
      서울에서 상하이, 도쿄, 하노이까지.<br class="mobile-br" />
      바나바브릿지는 검증된 프로세스와 계약으로 A와 B를 잇는 글로벌 에이전시입니다.
    </p>
    <div class="hero-cta">
      <a class="btn btn-gold" href={`tel:${SITE.phone}`}>
        <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/>
        </svg>
        지금 바로 전화 연결
      </a>
      <a class="btn btn-ghost" href="#works">레퍼런스 보기</a>
    </div>

    <ul class="hero-stats">
      <li><strong>SINCE 2023</strong><span>법인 운영</span></li>
      <li><strong>KR · CN · JP · VN</strong><span>글로벌 프로젝트</span></li>
      <li><strong>100%</strong><span>계약 기반 진행</span></li>
    </ul>
  </div>

  <div class="scroll-hint" aria-hidden="true">
    <span></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: calc(var(--header-h) + 40px) 0 80px;
    overflow: hidden;
  }
  #bridge-canvas {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
  }
  .hero-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(60% 50% at 70% 20%, rgba(207, 169, 107, 0.10), transparent 70%),
      radial-gradient(50% 45% at 15% 85%, rgba(207, 169, 107, 0.06), transparent 70%);
    pointer-events: none;
  }
  .hero-inner { position: relative; z-index: 2; }

  h1 {
    margin-top: 22px;
    font-size: clamp(38px, 7vw, 72px);
    font-weight: 800;
    line-height: 1.18;
    letter-spacing: -0.03em;
  }
  h1 em {
    font-style: normal;
    background: linear-gradient(120deg, var(--gold-soft), var(--gold));
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
  }
  .hero-sub {
    margin-top: 22px;
    max-width: 620px;
    color: var(--ink-dim);
    font-size: clamp(16px, 2vw, 18.5px);
  }
  .mobile-br { display: none; }

  .hero-cta {
    margin-top: 36px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }

  .hero-stats {
    margin-top: 64px;
    display: flex;
    gap: clamp(28px, 6vw, 72px);
    list-style: none;
    flex-wrap: wrap;
  }
  .hero-stats li { display: flex; flex-direction: column; gap: 4px; }
  .hero-stats strong {
    font-size: clamp(17px, 2.2vw, 21px);
    letter-spacing: 0.02em;
    color: var(--ink);
  }
  .hero-stats span { font-size: 13px; color: var(--muted); }

  .scroll-hint {
    position: absolute;
    bottom: 26px;
    left: 50%;
    transform: translateX(-50%);
    width: 22px;
    height: 36px;
    border: 1.5px solid var(--line-strong);
    border-radius: 12px;
    z-index: 2;
  }
  .scroll-hint span {
    position: absolute;
    top: 7px;
    left: 50%;
    width: 3px;
    height: 7px;
    margin-left: -1.5px;
    border-radius: 2px;
    background: var(--gold);
    animation: hint 1.8s ease-in-out infinite;
  }
  @keyframes hint {
    0% { transform: translateY(0); opacity: 1; }
    70% { transform: translateY(11px); opacity: 0; }
    100% { transform: translateY(0); opacity: 0; }
  }

  @media (max-width: 560px) {
    .mobile-br { display: block; }
    .scroll-hint { display: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-hint span { animation: none; }
  }
</style>

<script>
  // ============================================================
  // A → B 브릿지 파티클 애니메이션 (경량 Canvas 2D)
  // - 키워드가 A(왼쪽)에서 B(오른쪽)로 아치를 그리며 건너감
  // - reduced-motion / 탭 비활성 시 정지, DPR 2 제한 → 렉 방지
  // ============================================================
  const canvas = document.getElementById('bridge-canvas') as HTMLCanvasElement | null;

  if (canvas && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const ctx = canvas.getContext('2d')!;
    const WORDS = [
      'ARTIST', 'STAGE', 'BRAND', 'MARKET', 'FAN MEETING', 'CONCERT',
      'SEOUL', 'SHANGHAI', 'TOKYO', 'HANOI', 'CONTRACT', 'GLOBAL',
    ];
    const GOLD = '207, 169, 107';

    let w = 0, h = 0, dpr = 1, raf = 0;

    interface Traveler {
      t: number;      // 0~1 경로 진행도
      speed: number;
      word: string;
      size: number;
      wobble: number; // 경로에서 살짝 벗어나는 흔들림
    }
    interface Dot { x: number; y: number; r: number; a: number; tw: number }

    let travelers: Traveler[] = [];
    let dots: Dot[] = [];

    function resize() {
      dpr = Math.min(devicePixelRatio || 1, 2);
      w = canvas.clientWidth;
      h = canvas.clientHeight;
      canvas.width = w * dpr;
      canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

      const n = w < 700 ? 5 : 9;
      travelers = Array.from({ length: n }, (_, i) => ({
        t: i / n,
        speed: 0.0009 + Math.random() * 0.0009,
        word: WORDS[(Math.random() * WORDS.length) | 0],
        size: 10 + Math.random() * 3,
        wobble: (Math.random() - 0.5) * 36,
      }));
      const dn = w < 700 ? 26 : 54;
      dots = Array.from({ length: dn }, () => ({
        x: Math.random() * w,
        y: Math.random() * h,
        r: 0.6 + Math.random() * 1.4,
        a: 0.08 + Math.random() * 0.22,
        tw: Math.random() * Math.PI * 2,
      }));
    }

    // 아치형 브릿지 경로 (2차 베지어)
    function path(t: number, wobble: number) {
      const x0 = -40, y0 = h * 0.82;
      const cx = w * 0.5, cy = h * 0.16;
      const x1 = w + 40, y1 = h * 0.72;
      const mt = 1 - t;
      const x = mt * mt * x0 + 2 * mt * t * cx + t * t * x1;
      const y = mt * mt * y0 + 2 * mt * t * cy + t * t * y1 + wobble * Math.sin(t * Math.PI);
      return { x, y };
    }

    let time = 0;
    function frame() {
      time += 1;
      ctx.clearRect(0, 0, w, h);

      // 배경 별처럼 흩어진 점
      for (const d of dots) {
        const a = d.a * (0.6 + 0.4 * Math.sin(time * 0.02 + d.tw));
        ctx.fillStyle = `rgba(${GOLD}, ${a})`;
        ctx.beginPath();
        ctx.arc(d.x, d.y, d.r, 0, Math.PI * 2);
        ctx.fill();
      }

      // 브릿지 경로 (은은한 곡선)
      ctx.strokeStyle = `rgba(${GOLD}, 0.10)`;
      ctx.lineWidth = 1;
      ctx.beginPath();
      for (let i = 0; i <= 60; i++) {
        const p = path(i / 60, 0);
        i === 0 ? ctx.moveTo(p.x, p.y) : ctx.lineTo(p.x, p.y);
      }
      ctx.stroke();

      // 이동하는 키워드 + 궤적
      ctx.textBaseline = 'middle';
      for (const tr of travelers) {
        tr.t += tr.speed;
        if (tr.t > 1.05) {
          tr.t = -0.05;
          tr.word = WORDS[(Math.random() * WORDS.length) | 0];
        }
        const p = path(Math.max(0, Math.min(1, tr.t)), tr.wobble);
        // 가장자리 페이드
        const edge = Math.min(tr.t, 1 - tr.t);
        const alpha = Math.max(0, Math.min(1, edge * 8));

        // 궤적 점
        ctx.fillStyle = `rgba(${GOLD}, ${0.65 * alpha})`;
        ctx.beginPath();
        ctx.arc(p.x, p.y, 2.2, 0, Math.PI * 2);
        ctx.fill();

        // 키워드
        ctx.font = `600 ${tr.size}px Pretendard, sans-serif`;
        ctx.fillStyle = `rgba(${GOLD}, ${0.5 * alpha})`;
        ctx.fillText(tr.word, p.x + 8, p.y - 8);
      }

      raf = requestAnimationFrame(frame);
    }

    function start() { if (!raf) raf = requestAnimationFrame(frame); }
    function stop() { cancelAnimationFrame(raf); raf = 0; }

    // ResizeObserver: 스타일 적용·창 크기 변경 시 자동 재측정 (초기 0 크기 방지)
    const ro = new ResizeObserver(() => resize());
    ro.observe(canvas);
    resize();
    start();
    document.addEventListener('visibilitychange', () =>
      document.hidden ? stop() : start()
    );
  }
</script>
