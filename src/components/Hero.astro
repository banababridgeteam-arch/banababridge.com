---
import { SITE } from '../config';
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="hero" id="top">
  <div class="hero-bg" aria-hidden="true"></div>
  <canvas id="bridge-canvas" aria-hidden="true"></canvas>
  <div class="hero-veil" aria-hidden="true"></div>

  <div class="container hero-inner">
    <p class="hero-badge reveal">{t.hero.badge}</p>
    <h1 class="display h-xl hero-title reveal">
      <span>{t.hero.line1}</span>
      <span>{t.hero.line2}</span>
    </h1>
    <p class="lead hero-sub reveal">{t.hero.sub}</p>
    <div class="hero-cta reveal">
      {SITE.phone ? (
        <a class="btn btn-gold" href={`tel:${SITE.phone}`}>{t.cta.call}</a>
      ) : (
        <a class="btn btn-gold" href={`mailto:${SITE.email}`}>{t.cta.inquire}</a>
      )}
      <a class="btn btn-ghost" href="#work">{t.nav.work}</a>
    </div>
  </div>

  <span class="scroll-tag" aria-hidden="true">{t.hero.scroll}</span>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding: calc(var(--header-h) + 48px) 0 96px;
    overflow: hidden;
  }
  .hero-bg {
    position: absolute;
    inset: 0;
    background: url('/og-default.jpg') center / cover no-repeat;
    opacity: 0.42;
  }
  .hero-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.55) 0%, rgba(0,0,0,0.35) 40%, rgba(0,0,0,0.95) 100%);
  }
  #bridge-canvas { position: absolute; inset: 0; width: 100%; height: 100%; }
  .hero-veil {
    position: absolute;
    inset: 0;
    background: radial-gradient(60% 55% at 72% 22%, rgba(201,162,94,0.10), transparent 70%);
    pointer-events: none;
  }
  .hero-inner { position: relative; z-index: 2; }

  .hero-badge {
    font-size: 12.5px;
    font-weight: 500;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--gold);
  }
  .hero-title { margin-top: 22px; }
  .hero-title span { display: block; }
  .hero-title span:last-child { color: var(--ink-dim); }

  .hero-sub { margin-top: 26px; }
  .hero-cta { margin-top: 38px; display: flex; gap: 14px; flex-wrap: wrap; }

  .scroll-tag {
    position: absolute;
    bottom: 30px;
    left: 50%;
    transform: translateX(-50%);
    font-size: 11px;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--muted);
    z-index: 2;
  }
  .scroll-tag::after {
    content: '';
    display: block;
    width: 1px;
    height: 26px;
    margin: 8px auto 0;
    background: linear-gradient(var(--gold), transparent);
    animation: drop 1.9s ease-in-out infinite;
    transform-origin: top;
  }
  @keyframes drop { 0% { transform: scaleY(0); } 50% { transform: scaleY(1); } 100% { transform: scaleY(0); transform-origin: bottom; } }
  @media (max-width: 560px) { .scroll-tag { display: none; } }
  @media (prefers-reduced-motion: reduce) { .scroll-tag::after { animation: none; } }
</style>

<script>
  // A → B 브릿지 파티클 (경량 Canvas 2D · 화면 밖/백그라운드 자동 정지 · 델타타임)
  const canvas = document.getElementById('bridge-canvas') as HTMLCanvasElement | null;
  if (canvas && !matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const ctx = canvas.getContext('2d')!;
    const WORDS = ['ARTIST','STAGE','BRAND','MARKET','SEOUL','SHANGHAI','TOKYO','HANOI','CONTRACT','GLOBAL'];
    const GOLD = '201, 162, 94';
    let w = 0, h = 0, dpr = 1, raf = 0, time = 0, last = 0;

    interface T { t: number; speed: number; word: string; size: number; wob: number }
    interface D { x: number; y: number; r: number; a: number; tw: number }
    const trav: T[] = [], dots: D[] = [];
    const mkT = (t: number): T => ({ t, speed: 0.05 + Math.random() * 0.05, word: WORDS[(Math.random()*WORDS.length)|0], size: 10 + Math.random()*3, wob: (Math.random()-0.5)*34 });
    const mkD = (): D => ({ x: Math.random()*w, y: Math.random()*h, r: 0.6 + Math.random()*1.3, a: 0.06 + Math.random()*0.2, tw: Math.random()*6.28 });

    function resize() {
      const pw = w, ph = h;
      w = canvas.clientWidth; h = canvas.clientHeight;
      if (!w || !h) return;
      dpr = Math.min(devicePixelRatio || 1, 2);
      canvas.width = w * dpr; canvas.height = h * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      const n = w < 700 ? 5 : 9, dn = w < 700 ? 22 : 46;
      if (pw && ph) for (const d of dots) { d.x *= w/pw; d.y *= h/ph; }
      while (trav.length < n) trav.push(mkT(trav.length / n));
      trav.length = Math.min(trav.length, n);
      while (dots.length < dn) dots.push(mkD());
      dots.length = Math.min(dots.length, dn);
    }
    function path(t: number, wob: number) {
      const x0=-40, y0=h*0.82, cx=w*0.5, cy=h*0.14, x1=w+40, y1=h*0.72, mt=1-t;
      return { x: mt*mt*x0 + 2*mt*t*cx + t*t*x1, y: mt*mt*y0 + 2*mt*t*cy + t*t*y1 + wob*Math.sin(t*Math.PI) };
    }
    function frame(now: number) {
      if (!last) last = now;
      const dt = Math.min(now - last, 50); last = now; time += dt/1000;
      ctx.clearRect(0, 0, w, h);
      for (const d of dots) {
        const a = d.a * (0.6 + 0.4 * Math.sin(time*1.2 + d.tw));
        ctx.fillStyle = `rgba(${GOLD}, ${a})`;
        ctx.beginPath(); ctx.arc(d.x, d.y, d.r, 0, 6.283); ctx.fill();
      }
      ctx.strokeStyle = `rgba(${GOLD}, 0.10)`; ctx.lineWidth = 1;
      ctx.beginPath();
      for (let i = 0; i <= 60; i++) { const p = path(i/60, 0); i ? ctx.lineTo(p.x, p.y) : ctx.moveTo(p.x, p.y); }
      ctx.stroke();
      ctx.textBaseline = 'middle';
      for (const tr of trav) {
        tr.t += (tr.speed * dt) / 1000;
        if (tr.t > 1.05) { tr.t = -0.05; tr.word = WORDS[(Math.random()*WORDS.length)|0]; }
        const p = path(Math.max(0, Math.min(1, tr.t)), tr.wob);
        const alpha = Math.max(0, Math.min(1, Math.min(tr.t, 1-tr.t) * 8));
        ctx.fillStyle = `rgba(${GOLD}, ${0.6*alpha})`;
        ctx.beginPath(); ctx.arc(p.x, p.y, 2.1, 0, 6.283); ctx.fill();
        ctx.font = `500 ${tr.size}px Inter, sans-serif`;
        ctx.fillStyle = `rgba(${GOLD}, ${0.45*alpha})`;
        ctx.fillText(tr.word, p.x + 8, p.y - 8);
      }
      raf = requestAnimationFrame(frame);
    }
    function start() { if (!raf) { last = 0; raf = requestAnimationFrame(frame); } }
    function stop() { cancelAnimationFrame(raf); raf = 0; }
    let onScreen = true;
    const sync = () => (onScreen && !document.hidden ? start() : stop());
    new IntersectionObserver(([e]) => { onScreen = e.isIntersecting; sync(); }).observe(canvas);
    document.addEventListener('visibilitychange', sync);
    new ResizeObserver(() => resize()).observe(canvas);
    resize(); sync();
  }
</script>
