---
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section" id="about">
  <div class="container">
    <p class="index-label reveal"><span class="num">01</span><span class="txt">{t.about.label}</span></p>
    <h2 class="display h-lg about-head reveal">{t.about.head}</h2>
    <p class="lead about-body reveal">{t.about.body}</p>
  </div>
</section>

<style>
  .about-head { max-width: 14ch; }
  .about-body { margin-top: 28px; max-width: 640px; font-size: clamp(16px, 1.8vw, 20px); color: var(--ink-dim); }
</style>
