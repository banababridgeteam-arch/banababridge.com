---
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section" id="about">
  <div class="container">
    <p class="index-label reveal"><span class="num">01</span><span class="txt">{t.about.label}</span></p>

    <p class="about-statement reveal">
      <b>{t.about.head}</b> {t.about.body}
    </p>

    <p class="about-ax reveal">
      <span class="ax-tag">AX</span>{t.about.ax}
    </p>
  </div>
</section>

<style>
  /* strove About: 라벨 + 32px 선언문 */
  .about-statement {
    margin-top: clamp(28px, 3.4vw, 48px);
    max-width: 24ch;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(23px, 2.8vw, 34px);
    line-height: 1.32;
    letter-spacing: -0.03em;
    color: var(--ink);
  }
  .about-statement b { font-weight: 600; }
  .about-ax {
    max-width: 720px;
    margin-top: clamp(32px, 4vw, 56px);
    padding: 22px 24px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: linear-gradient(180deg, var(--bg-2), var(--bg));
    color: var(--ink-dim);
    font-size: 15px;
    line-height: 1.65;
  }
  .ax-tag {
    display: inline-block;
    margin-right: 8px;
    padding: 2px 9px;
    border-radius: 6px;
    background: linear-gradient(135deg, var(--gold-soft), var(--gold));
    color: #16110a;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    vertical-align: 2px;
  }
  @media (max-width: 760px) { .about-statement { max-width: none; } }
</style>
