---
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section" id="about">
  <div class="container">
    <p class="index-label reveal"><span class="num">01</span><span class="txt">{t.about.label}</span></p>
    <h2 class="display h-lg about-head reveal mask-head">
      <span class="ml"><span>{t.about.head}</span></span>
    </h2>
    <div class="about-cols">
      <p class="lead about-body reveal">{t.about.body}</p>
      <p class="about-ax reveal">
        <span class="ax-tag">AX</span>
        {t.about.ax}
      </p>
    </div>
  </div>
</section>

<style>
  .about-head { max-width: 16ch; }
  .about-cols {
    margin-top: 32px;
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: clamp(28px, 4vw, 64px);
    align-items: start;
  }
  .about-body { font-size: clamp(16px, 1.8vw, 20px); color: var(--ink-dim); }
  .about-ax {
    position: relative;
    padding: 22px 24px;
    border: 1px solid var(--line);
    border-radius: 14px;
    background: linear-gradient(180deg, var(--bg-2), var(--bg));
    color: var(--ink-dim);
    font-size: 15px;
    line-height: 1.65;
  }
  .ax-tag {
    display: inline-block;
    margin-right: 8px;
    padding: 2px 9px;
    border-radius: 6px;
    background: linear-gradient(135deg, var(--gold-soft), var(--gold));
    color: #16110a;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: 12px;
    letter-spacing: 0.06em;
    vertical-align: 2px;
  }
  @media (max-width: 820px) { .about-cols { grid-template-columns: 1fr; } }
</style>
