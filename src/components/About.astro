---
import SectionHead from './SectionHead.astro';
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section" id="about">
  <div class="container">
    <p class="index-label reveal"><span class="num">01</span><span class="txt">{t.about.label}</span></p>
    <SectionHead num="01" text={t.about.head} />

    <div class="about-grid">
      <p class="about-body reveal">{t.about.body}</p>
      <p class="about-ax reveal">
        <span class="ax-tag">AX</span>{t.about.ax}
      </p>
    </div>
  </div>
</section>

<style>
  .about-grid {
    margin-top: clamp(32px, 4vw, 64px);
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(32px, 5vw, 88px);
    align-items: start;
  }
  .about-body {
    max-width: 60ch;
    font-size: clamp(16px, 1.6vw, 20px);
    line-height: 1.7;
    color: var(--ink-dim);
  }
  .about-ax {
    padding: 20px 22px;
    border: 1px solid var(--line);
    border-radius: 0;
    background: linear-gradient(180deg, var(--bg-2), var(--bg));
    color: var(--muted);
    font-size: 14px;
    line-height: 1.6;
  }
  .ax-tag {
    display: inline-block;
    margin-right: 8px;
    padding: 2px 9px;
    border-radius: 6px;
    background: linear-gradient(135deg, var(--rose), var(--lav));
    color: var(--ink-on-accent);
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 12px;
    letter-spacing: 0.06em;
    vertical-align: 2px;
  }

  @media (max-width: 860px) {
    .about-grid { grid-template-columns: 1fr; gap: 28px; }
  }
</style>
