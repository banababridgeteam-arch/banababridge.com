---
// 무한 스크롤 마퀴 — 진출 도시/키워드 (언어 무관, 프리미엄 영문 고정)
const items = ['SEOUL', 'SHANGHAI', 'TOKYO', 'HANOI', 'HO CHI MINH', 'HONG KONG'];
---

<div class="marquee" aria-hidden="true">
  <div class="marquee-track">
    {[0, 1].map(() => (
      <div class="marquee-group">
        {items.map((it) => (
          <span class="marquee-item">{it}<span class="dot">✦</span></span>
        ))}
      </div>
    ))}
  </div>
</div>
