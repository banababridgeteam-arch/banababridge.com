---
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="stats section" id="stats">
  <div class="container stats-grid">
    {t.stats.items.map((s) => (
      <div class="stat reveal">
        <span class="stat-value display odo" data-value={s.value}>{s.value}</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  .stat { display: flex; flex-direction: column; gap: 14px; }
  .stat-value { font-size: clamp(48px, 8vw, 112px); font-weight: 600; letter-spacing: -0.06em; line-height: 1; color: var(--ink); }
  .stat-label { font-size: 14px; color: var(--muted); }
  @media (max-width: 620px) { .stats-grid { grid-template-columns: 1fr; gap: 44px; } }
</style>

<script>
  // 오도미터 — 화면 진입 시 각 자리 숫자가 슬롯머신처럼 굴러 목표값으로
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

  function buildOdo(el: HTMLElement) {
    const value = el.dataset.value || '';
    el.textContent = '';
    const strips: { strip: HTMLElement; digit: number }[] = [];
    for (const ch of value) {
      if (/\d/.test(ch)) {
        const col = document.createElement('span');
        col.className = 'odo-col';
        const strip = document.createElement('span');
        strip.className = 'odo-strip';
        // 0-9 를 두 바퀴(스핀 효과) 쌓기
        for (let cycle = 0; cycle < 2; cycle++)
          for (let n = 0; n <= 9; n++) {
            const s = document.createElement('span');
            s.textContent = String(n);
            strip.appendChild(s);
          }
        col.appendChild(strip);
        el.appendChild(col);
        strips.push({ strip, digit: parseInt(ch, 10) });
      } else {
        const s = document.createElement('span');
        s.textContent = ch;
        el.appendChild(s);
      }
    }
    // 최종 위치로 굴리기 (두 번째 바퀴의 목표 숫자 = -(10 + digit)em)
    requestAnimationFrame(() => {
      strips.forEach(({ strip, digit }, i) => {
        strip.style.transitionDelay = `${i * 0.08}s`;
        strip.style.transform = reduce ? `translateY(-${digit}em)` : `translateY(-${10 + digit}em)`;
      });
    });
  }

  const io = new IntersectionObserver((es) => {
    for (const e of es) if (e.isIntersecting) { buildOdo(e.target as HTMLElement); io.unobserve(e.target); }
  }, { threshold: 0.5 });
  document.querySelectorAll<HTMLElement>('.odo[data-value]').forEach((el) => io.observe(el));
</script>
