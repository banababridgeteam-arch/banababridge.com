---
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="stats" id="stats">
  <div class="container stats-grid">
    {t.stats.items.map((s) => (
      <div class="stat reveal">
        <span class="stat-value display count" data-count={s.value}>0</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .stats { padding: clamp(64px, 8vw, 112px) 0; border-top: 1px solid var(--line); }
  .stats-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 40px; }
  .stat { display: flex; flex-direction: column; gap: 12px; }
  .stat-value { font-size: clamp(46px, 8vw, 104px); font-weight: 600; letter-spacing: -0.04em; line-height: 1; color: var(--ink); }
  .stat-label { font-size: 14px; color: var(--muted); }
  @media (max-width: 760px) { .stats-grid { grid-template-columns: 1fr; gap: 40px; } }
</style>

<script>
  // 카운트업 (슬롯머신 느낌) — 화면 진입 시 0 → 목표값
  const nums = document.querySelectorAll<HTMLElement>('.count[data-count]');
  const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;
  const run = (el: HTMLElement) => {
    const target = parseInt(el.dataset.count || '0', 10);
    if (reduce || !target) { el.textContent = String(target); return; }
    const dur = 1400;
    let start = 0;
    const step = (now: number) => {
      if (!start) start = now;
      const p = Math.min((now - start) / dur, 1);
      const eased = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(target * eased).toString();
      if (p < 1) requestAnimationFrame(step);
      else el.textContent = String(target);
    };
    requestAnimationFrame(step);
  };
  const io = new IntersectionObserver((es) => {
    for (const e of es) if (e.isIntersecting) { run(e.target as HTMLElement); io.unobserve(e.target); }
  }, { threshold: 0.5 });
  nums.forEach((n) => io.observe(n));
</script>
