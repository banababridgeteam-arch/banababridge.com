---
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="stats">
  <div class="container stats-grid">
    {t.stats.items.map((s) => (
      <div class="stat reveal">
        <span class="stat-value display">{s.value}</span>
        <span class="stat-label">{s.label}</span>
      </div>
    ))}
  </div>
</section>

<style>
  .stats { padding: clamp(56px, 7vw, 96px) 0; border-top: 1px solid var(--line); }
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }
  .stat { display: flex; flex-direction: column; gap: 8px; }
  .stat-value { font-size: clamp(22px, 3vw, 40px); font-weight: 600; letter-spacing: -0.02em; color: var(--ink); }
  .stat-label { font-size: 13.5px; color: var(--muted); }
  @media (max-width: 720px) {
    .stats-grid { grid-template-columns: 1fr; gap: 24px; }
  }
</style>
