---
import { SITE } from '../config';
import { type Lang, defaultLang, localizePath, useTranslations } from '../i18n/ui';
import RollingText from './RollingText.astro';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
const p = (path: string) => localizePath(path, lang);
const year = new Date().getFullYear();

const backTop = lang === 'ko' ? '맨 위로' : lang === 'zh' ? '返回顶部' : lang === 'vi' ? 'Lên đầu trang' : 'Back to top';
---

<footer class="site-footer">
  <div class="footer-inner container">
    <div class="footer-top">
      <a class="footer-back roll" href="#top">
        <span class="dot" aria-hidden="true"></span>
        <RollingText text={backTop} />
      </a>
      <p class="footer-tag">{t.footer.tagline}</p>
    </div>

    <div class="footer-links">
      <div class="fl-col">
        <p class="fl-head">{t.footer.menu}</p>
        <a href={p('/') + '#work'}>{t.nav.work}</a>
        <a href={p('/') + '#services'}>{t.nav.services}</a>
        <a href={p('/') + '#about'}>{t.nav.about}</a>
        <a href="/insights/">{t.nav.insights}</a>
      </div>
      <div class="fl-col">
        <p class="fl-head">Social</p>
        <a href="https://www.instagram.com/banababridge/" target="_blank" rel="noopener">Instagram</a>
        <a href={`mailto:${SITE.email}`}>Email</a>
        <a href="/privacy/">{t.footer.privacy}</a>
      </div>
      <div class="fl-col fl-contact">
        <p class="fl-head">{t.nav.contact}</p>
        <a class="fl-mail" href={`mailto:${SITE.email}`}>{SITE.email}</a>
      </div>
    </div>

    <div class="footer-wordmark" aria-hidden="true">BANABA BRIDGE<span>®</span></div>

    <div class="footer-legal">
      <p>{SITE.legalName} · {SITE.bizNumber} · {lang === 'ko' ? SITE.address : SITE.addressEn}</p>
      <p>© {year} {SITE.legalNameEn}. {t.footer.rights}</p>
    </div>
  </div>
</footer>

<style>
  /* 대비 푸터 — 나이트 가든의 '여명(dawn)' : 문라이트 라일락 패널 */
  .site-footer {
    --ftxt: #1b1533;            /* 딥 플럼 (밝은 배경 위 텍스트) */
    --fmuted: rgba(27, 21, 51, 0.56);
    --fline: rgba(27, 21, 51, 0.2);
    background: linear-gradient(165deg, #cabce9 0%, #d6c0e2 52%, #e0c4dc 100%);
    color: var(--ftxt);
    overflow: hidden;
  }
  .footer-inner { padding-top: clamp(48px, 6vw, 88px); padding-bottom: 32px; }

  .footer-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 32px;
    flex-wrap: wrap;
    padding-bottom: clamp(40px, 5vw, 72px);
    border-bottom: 1px solid var(--fline);
  }
  .footer-back {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 12px 22px;
    border-radius: 999px;
    background: #17122e;
    color: #ece7fb;
    font-family: var(--font-display);
    font-weight: 400;
    font-size: 15px;
    transition: transform 0.3s cubic-bezier(0.22, 1, 0.36, 1), background 0.3s ease;
  }
  .footer-back:hover { transform: translateY(-2px); background: #0f0b22; }
  .footer-back .dot { width: 7px; height: 7px; border-radius: 50%; background: var(--rose); }
  .footer-tag {
    max-width: 20ch;
    text-align: right;
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(18px, 2.2vw, 28px);
    letter-spacing: -0.03em;
    line-height: 1.15;
    color: var(--ftxt);
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 220px));
    justify-content: start;
    gap: clamp(32px, 6vw, 96px);
    padding: clamp(40px, 5vw, 72px) 0;
  }
  .fl-head {
    font-family: var(--font-display);
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fmuted);
    margin-bottom: 16px;
  }
  .fl-col a {
    display: block;
    padding: 5px 0;
    font-size: 16px;
    font-weight: 500;
    color: var(--ftxt);
    transition: opacity 0.2s ease;
  }
  .fl-col a:hover { opacity: 0.6; }
  .fl-contact .fl-mail { font-size: clamp(15px, 1.6vw, 19px); text-decoration: underline; text-underline-offset: 4px; }

  .footer-wordmark {
    margin: clamp(8px, 2vw, 24px) 0 clamp(20px, 3vw, 40px);
    font-family: var(--font-display);
    font-weight: 400;
    font-size: clamp(44px, 11vw, 202px);
    line-height: 0.9;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    white-space: nowrap;
    color: #17122e;
  }
  .footer-wordmark span { color: var(--violet); font-size: 0.24em; vertical-align: 0.42em; margin-left: 0.04em; }
  @media (max-width: 720px) {
    .footer-wordmark { white-space: normal; font-size: clamp(40px, 15vw, 120px); line-height: 0.9; }
  }

  .footer-legal {
    display: flex;
    justify-content: space-between;
    gap: 20px;
    flex-wrap: wrap;
    padding-top: 22px;
    border-top: 1px solid var(--fline);
    font-size: 12.5px;
    color: var(--fmuted);
  }

  @media (max-width: 720px) {
    .footer-links { grid-template-columns: 1fr 1fr; }
    .footer-tag { text-align: left; }
  }
  @media (max-width: 460px) { .footer-links { grid-template-columns: 1fr; } }
</style>
