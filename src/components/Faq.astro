---
import SectionHead from './SectionHead.astro';
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';
interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section" id="faq">
  <div class="container">
    <SectionHead num="05" text={t.faq.head} />

    <div class="faq-list">
      {t.faq.items.map((f, i) => (
        <details class="faq-item reveal" open={i === 0}>
          <summary>
            <span>{f.q}</span>
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path d="m6 9 6 6 6-6" />
            </svg>
          </summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list { margin-top: clamp(40px, 5vw, 72px); max-width: 760px; }
  .faq-item { border-bottom: 1px solid var(--line); }
  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    padding: clamp(20px, 2.4vw, 30px) 0;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-size: clamp(18px, 2vw, 26px);
    font-weight: 500;
    letter-spacing: -0.02em;
    transition: color 0.2s ease;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary:hover { color: var(--gold-soft); }
  .faq-item summary svg { flex-shrink: 0; color: var(--gold); transition: transform 0.3s ease; }
  .faq-item[open] summary svg { transform: rotate(180deg); }
  .faq-item p {
    padding: 0 0 clamp(22px, 2.4vw, 30px);
    max-width: none;
    color: var(--ink-dim);
    font-size: clamp(15.5px, 1.5vw, 17px);
    line-height: 1.7;
  }
</style>
