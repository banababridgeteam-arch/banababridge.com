---
import { faqs } from '../data/faqs';
---

<section class="section" id="faq">
  <div class="container">
    <p class="eyebrow reveal">FAQ</p>
    <h2 class="h2 reveal">자주 묻는 질문</h2>

    <div class="faq-list">
      {faqs.map((f, i) => (
        <details class="faq-item reveal" open={i === 0}>
          <summary>
            <span>{f.q}</span>
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" aria-hidden="true">
              <path d="m6 9 6 6 6-6" />
            </svg>
          </summary>
          <p>{f.a}</p>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-list {
    margin-top: 44px;
    max-width: 780px;
    display: flex;
    flex-direction: column;
  }
  .faq-item { border-bottom: 1px solid var(--line); }
  .faq-item summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    padding: 22px 4px;
    cursor: pointer;
    font-size: 16.5px;
    font-weight: 600;
    list-style: none;
    transition: color 0.2s ease;
  }
  .faq-item summary::-webkit-details-marker { display: none; }
  .faq-item summary:hover { color: var(--gold-soft); }
  .faq-item summary svg {
    flex-shrink: 0;
    color: var(--gold);
    transition: transform 0.3s ease;
  }
  .faq-item[open] summary svg { transform: rotate(180deg); }
  .faq-item p {
    padding: 0 4px 24px;
    color: var(--ink-dim);
    font-size: 15px;
    max-width: 680px;
  }
</style>
