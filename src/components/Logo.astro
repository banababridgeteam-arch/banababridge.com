---
// 바나바브릿지 로고 — 현수교(suspension bridge) 마크 + 워드마크
interface Props { href?: string; class?: string }
const { href = '/', class: cls = '' } = Astro.props;
---

<a href={href} class={`logo ${cls}`} aria-label="BANABA BRIDGE">
  <svg class="logo-mark" viewBox="0 0 50 30" fill="none" aria-hidden="true">
    <path d="M3 25 Q25 3 47 25" stroke="url(#lg)" stroke-width="2" stroke-linecap="round" />
    <line x1="14" y1="14.4" x2="14" y2="25" stroke="url(#lg)" stroke-width="1.2" opacity="0.75" />
    <line x1="25" y1="9" x2="25" y2="25" stroke="url(#lg)" stroke-width="1.2" opacity="0.75" />
    <line x1="36" y1="14.4" x2="36" y2="25" stroke="url(#lg)" stroke-width="1.2" opacity="0.75" />
    <circle cx="3" cy="25" r="3" fill="#e4ca94" />
    <circle cx="47" cy="25" r="3" fill="#e4ca94" />
    <defs>
      <linearGradient id="lg" x1="0" y1="0" x2="50" y2="0" gradientUnits="userSpaceOnUse">
        <stop stop-color="#c9a25e" />
        <stop offset="0.5" stop-color="#e4ca94" />
        <stop offset="1" stop-color="#c9a25e" />
      </linearGradient>
    </defs>
  </svg>
  <span class="logo-word">BANABA<span>BRIDGE</span></span>
</a>

<style>
  .logo { display: inline-flex; align-items: center; gap: 10px; }
  .logo-mark { width: 30px; height: auto; flex-shrink: 0; }
  .logo-word {
    font-family: var(--font-display);
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.02em;
    line-height: 1;
  }
  .logo-word span { color: var(--gold); }
  @media (max-width: 420px) { .logo-word { font-size: 14px; } }
</style>
