---
// 바나바브릿지 로고 — 마주보는 BB 모노그램(M1) + 워드마크
// 마크=라벤더 / BANABA=아이보리 / BRIDGE=로즈 (나이트 가든 팔레트)
interface Props { href?: string; class?: string }
const { href = '/', class: cls = '' } = Astro.props;
---

<a href={href} class={`logo ${cls}`} aria-label="BANABA BRIDGE">
  <svg class="logo-mark" viewBox="0 0 120 120" fill="none" aria-hidden="true">
    <g stroke="currentColor" stroke-width="12" stroke-linecap="butt" stroke-linejoin="round">
      <line x1="26" y1="24" x2="26" y2="96" />
      <path d="M26 24 h9 a17.5 18 0 0 1 0 36 h-9" />
      <path d="M26 60 h9 a17.5 18 0 0 1 0 36 h-9" />
      <line x1="94" y1="24" x2="94" y2="96" />
      <path d="M94 24 h-9 a17.5 18 0 0 0 0 36 h9" />
      <path d="M94 60 h-9 a17.5 18 0 0 0 0 36 h9" />
    </g>
  </svg>
  <span class="logo-word">BANABA<span>BRIDGE</span></span>
</a>

<style>
  .logo { display: inline-flex; align-items: center; gap: 11px; }
  .logo-mark {
    width: 42px; height: auto; flex-shrink: 0;
    color: var(--lav);
    transition: width 0.45s cubic-bezier(0.22, 1, 0.36, 1);
  }
  :global(.site-header.scrolled) .logo-mark { width: 34px; }
  .logo-word {
    font-family: var(--font-display);
    font-size: 15px;
    font-weight: 400;
    letter-spacing: 0.12em;
    line-height: 1;
    color: var(--ink);
  }
  .logo-word span { color: var(--rose); }
  @media (max-width: 420px) { .logo-mark { width: 36px; } .logo-word { font-size: 14px; } }
</style>
