---
// strove 스타일 초대형 섹션 헤딩 — "(02) 문장."
interface Props { num: string; text: string; class?: string }
const { num, text, class: cls = '' } = Astro.props;
---

<h2 class={`sec-head reveal mask-head ${cls}`}>
  <span class="ml"><span><em class="sec-num">({num})</em>{text}</span></span>
</h2>

<style>
  .sec-head {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(40px, 9.6vw, 144px); /* strove H1 = 144px */
    line-height: 1.1;
    letter-spacing: -0.06em; /* strove -8.64px/144px */
  }
  .sec-num {
    font-style: normal;
    font-size: 0.2em;
    color: var(--gold);
    vertical-align: 0.9em;
    letter-spacing: 0.02em;
    margin-right: 0.32em;
    font-weight: 500;
  }
</style>
