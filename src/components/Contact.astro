---
import { SITE } from '../config';
import SectionHead from './SectionHead.astro';
import { type Lang, defaultLang, useTranslations } from '../i18n/ui';

interface Props { lang?: Lang }
const { lang = defaultLang } = Astro.props;
const t = useTranslations(lang);
---

<section class="section contact" id="contact">
  <div class="container">
    <SectionHead num="04" text={t.contact.head} />
    <p class="lead reveal">{t.contact.body}</p>

    <div class="contact-actions reveal">
      {SITE.phone && (
        <a class="btn btn-gold" href={`tel:${SITE.phone}`}>{SITE.phoneDisplay} · {t.cta.call}</a>
      )}
      <a class={`btn ${SITE.phone ? 'btn-ghost' : 'btn-gold'}`} href={`mailto:${SITE.email}`}>
        {SITE.email}
      </a>
    </div>
  </div>
</section>

<style>
  .contact .lead { margin-top: 24px; }
  .contact-actions { margin-top: 40px; display: flex; gap: 14px; flex-wrap: wrap; }
</style>
