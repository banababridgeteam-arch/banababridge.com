---
import { SITE } from '../config';
---

<section class="section contact" id="contact">
  <div class="container">
    <div class="contact-box reveal">
      <p class="eyebrow">Contact</p>
      <h2 class="h2">
        연결이 필요하신가요?<br />지금 바로 이야기하시죠.
      </h2>
      <p class="lead">
        팬미팅·콘서트 에이전시, 아티스트 섭외, 브랜드 유통 제휴 —
        어떤 프로젝트든 <strong>영업일 기준 24시간 이내</strong>에 회신드립니다.
      </p>

      <div class="contact-actions">
        <a class="btn btn-gold" href={`tel:${SITE.phone}`}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.3-.3.7-.4 1-.2 1.1.4 2.3.6 3.6.6.6 0 1 .4 1 1V20c0 .6-.4 1-1 1C10.6 21 3 13.4 3 4c0-.6.4-1 1-1h3.5c.6 0 1 .4 1 1 0 1.2.2 2.4.6 3.6.1.3 0 .7-.2 1l-2.3 2.2z"/>
          </svg>
          {SITE.phoneDisplay} 전화 연결
        </a>
        <a class="btn btn-ghost" href={`mailto:${SITE.email}`}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <rect x="3" y="5" width="18" height="14" rx="2"/>
            <path d="m3 7 9 6 9-6"/>
          </svg>
          {SITE.email}
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  .contact-box {
    position: relative;
    padding: clamp(44px, 7vw, 80px) clamp(28px, 6vw, 72px);
    border: 1px solid var(--line-strong);
    border-radius: 20px;
    background:
      radial-gradient(80% 120% at 85% 0%, rgba(207, 169, 107, 0.12), transparent 60%),
      linear-gradient(180deg, var(--bg-2), var(--bg-3));
    overflow: hidden;
  }
  .contact-actions {
    margin-top: 36px;
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
  }
</style>
