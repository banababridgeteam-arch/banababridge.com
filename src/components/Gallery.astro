---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

// 현장 이미지 필름 스트립 — @banababridge 인스타그램 게시물
const igImages = import.meta.glob<{ default: ImageMetadata }>(
  '../assets/ig/*.jpg',
  { eager: true }
);
const pick = (name: string) =>
  Object.entries(igImages).find(([p]) => p.endsWith(name))?.[1].default;

const items = [
  { file: '07_1_DWl43nnEVMK_poster.jpg', alt: '티파니 홍콩 행사 — 박형식' },
  { file: '01_1_DaDEJb-yO6I.jpg', alt: '효민 상하이 팬미팅 My Hyomin Moment 포스터' },
  { file: '06_1_DW1a1ilkZXT.jpg', alt: 'SPECULUM × SEVENTEEN 캠페인' },
  { file: '04_1_DW3nKCqEd3l.jpg', alt: "효민 HYOMIN'S DAY 호치민 팬미팅 포스터" },
  { file: '02_1_DXT4uOVD4G2.jpg', alt: '효민 호치민 팬미팅 티켓 오픈' },
  { file: '05_1_DW1bdMUkXZM_poster.jpg', alt: 'SPECULUM × SEVENTEEN 커피차 서포트' },
  { file: '03_1_DXRT2XWDwZR.jpg', alt: '효민 호치민 팬미팅 티켓 오픈 D-1' },
]
  .map((i) => ({ ...i, img: pick(i.file) }))
  .filter((i) => i.img);
---

<section class="gallery" aria-label="현장 갤러리">
  <div class="container gallery-head">
    <p class="eyebrow reveal">Moments</p>
  </div>
  <div class="strip-viewport reveal">
    <div class="strip">
      {[0, 1].map((dup) => (
        <div class="strip-track" aria-hidden={dup === 1 ? 'true' : undefined}>
          {items.map((i) => (
            <figure class="shot">
              <Image src={i.img!} alt={dup === 0 ? i.alt : ''} height={300} loading="lazy" />
            </figure>
          ))}
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .gallery {
    padding: clamp(56px, 8vw, 96px) 0;
    border-top: 1px solid var(--line);
    overflow: hidden;
  }
  .gallery-head { margin-bottom: 30px; }

  .strip-viewport { overflow: hidden; }
  .strip {
    display: flex;
    width: max-content;
    animation: strip-scroll 55s linear infinite;
  }
  .strip:hover { animation-play-state: paused; }
  .strip-track { display: flex; gap: 16px; padding-right: 16px; }

  .shot {
    margin: 0;
    height: clamp(200px, 26vw, 300px);
    border-radius: 12px;
    overflow: hidden;
    border: 1px solid var(--line);
    flex-shrink: 0;
  }
  .shot :global(img) {
    height: 100%;
    width: auto;
    display: block;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .shot:hover :global(img) { transform: scale(1.03); }

  @keyframes strip-scroll {
    to { transform: translateX(-50%); }
  }

  @media (prefers-reduced-motion: reduce) {
    .strip { animation: none; }
    .strip-viewport { overflow-x: auto; }
  }
</style>
